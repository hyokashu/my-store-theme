{% comment %}
  Sprout — snippets/facets.liquid  v2
  ─────────────────────────────────────────────────────────────────────
  Usage: {%- render 'facets', results: collection -%}

  Renders THREE elements:
  ① <aside class="sdcl-sidebar">   — sticky left column on desktop (≥1024px)
       • FILTERS eyebrow + Clear All link (when active filters exist)
       • Sort-by select
       • Accordion filter groups (Space Grotesk Bold headers)
       • Price range inputs with Apply form
  ② <div class="sdcl-mobile-overlay">   — dark backdrop for mobile panel
  ③ <div class="sdcl-mobile-panel">     — slide-in filter panel on mobile
       • Sort-by radio links
       • Same accordion filter groups
       • Cancel / View Results footer

  JS (sd-collection.js) handles all open/close/accordion toggling.
  Filter links use Shopify-native url_to_add / url_to_remove — no JS
  required for the actual filtering.
{% endcomment %}

{%- liquid
  assign sort_by        = results.sort_by | default: results.default_sort_by
  assign active_filters = results.active_filters
  assign has_active     = false
  if active_filters.size > 0
    assign has_active = true
  endif
-%}

{%- comment -%} ════════════════════════════════════════════════════
    ①  DESKTOP SIDEBAR
════════════════════════════════════════════════════ {%- endcomment -%}

<aside class="sdcl-sidebar" id="sdcl-sidebar" aria-label="Product filters">

  {%- comment -%} ── Sidebar header ── {%- endcomment -%}
  <div class="sdcl-sidebar__header">
    <span class="sdcl-sidebar__title">Filters</span>
    {%- if has_active -%}
      <a
        href="{{ results.url | split: '?' | first }}"
        class="sdcl-sidebar__clear"
        aria-label="Clear all active filters"
      >Clear all</a>
    {%- endif -%}
  </div>

  {%- comment -%} ── Sort select (desktop sidebar) ── {%- endcomment -%}
  {%- if results.sort_options.size > 0 -%}
    <div class="sdcl-sidebar__sort">
      <label class="sdcl-sidebar__sort-label" for="sdcl-sort-desktop">Sort by</label>
      <select
        class="sdcf-sort-select sdcf-sort-select--full"
        id="sdcl-sort-desktop"
        aria-label="Sort products"
      >
        {%- for option in results.sort_options -%}
          <option
            value="{{ option.value | escape }}"
            {%- if option.value == sort_by %} selected{%- endif -%}
          >{{ option.name | escape }}</option>
        {%- endfor -%}
      </select>
    </div>
  {%- endif -%}

  {%- comment -%} ── Filter accordion groups ── {%- endcomment -%}
  {%- if results.filters.size > 0 -%}

    {%- for filter in results.filters -%}
      {%- liquid
        assign filter_has_active = false
        for value in filter.active_values
          assign filter_has_active = true
          break
        endfor
        if filter.type == 'price_range'
          if filter.min_value.value or filter.max_value.value
            assign filter_has_active = true
          endif
        endif
        assign acc_open = false
        if forloop.index <= 4
          assign acc_open = true
        endif
        if filter_has_active
          assign acc_open = true
        endif
      -%}

      <div
        class="sdcl-accordion{% if acc_open %} is-open{% endif %}"
        data-accordion="{{ forloop.index }}"
      >
        <button
          class="sdcl-accordion__header"
          type="button"
          aria-expanded="{{ acc_open }}"
          aria-controls="sdcl-acc-{{ forloop.index }}"
        >
          <span class="sdcl-accordion__label">{{ filter.label | escape }}</span>
          {%- if filter_has_active and filter.type != 'price_range' -%}
            <span class="sdcl-accordion__badge" aria-label="{{ filter.active_values.size }} selected">
              {{ filter.active_values.size }}
            </span>
          {%- endif -%}
          <svg class="sdcl-accordion__chevron" width="13" height="13"
            viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
            aria-hidden="true">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
        </button>

        <div class="sdcl-accordion__body" id="sdcl-acc-{{ forloop.index }}">

          {%- if filter.type == 'list' or filter.type == 'boolean' -%}
            <ul class="sdcl-accordion__list" role="list">
              {%- for value in filter.values -%}
                <li role="listitem">
                  <a
                    href="{{ value.url_to_add | default: value.url_to_remove }}"
                    class="sdcf-option__label{% if value.active %} is-active{% endif %}{% if value.count == 0 %} sdcf-option__label--disabled{% endif %}"
                    aria-pressed="{{ value.active }}"
                  >
                    <span class="sdcf-option__check" aria-hidden="true"></span>
                    <span class="sdcf-option__text">{{ value.label | escape }}</span>
                    <span class="sdcf-option__count">{{ value.count }}</span>
                  </a>
                </li>
              {%- endfor -%}
            </ul>

          {%- elsif filter.type == 'price_range' -%}
            {%- comment -%} Price range with GET form ── {%- endcomment -%}
            <form
              id="sdcl-price-form-{{ forloop.index }}"
              method="GET"
              action="{{ routes.root_url }}collections/{{ results.handle }}"
              class="sdcl-price-range"
            >
              {%- comment -%} Preserve all other active filters ── {%- endcomment -%}
              {%- for f in results.filters -%}
                {%- unless f.type == 'price_range' -%}
                  {%- for v in f.active_values -%}
                    <input type="hidden" name="{{ v.param_name }}" value="{{ v.value | escape }}">
                  {%- endfor -%}
                {%- endunless -%}
              {%- endfor -%}
              {%- if sort_by != blank and sort_by != results.default_sort_by -%}
                <input type="hidden" name="sort_by" value="{{ sort_by | escape }}">
              {%- endif -%}

              <div class="sdcl-price-range__row">
                <div class="sdcl-price-range__field">
                  <label class="sdcl-price-range__label" for="sdcl-pmin-{{ forloop.index }}">Min</label>
                  <div class="sdcl-price-range__wrap">
                    <span class="sdcl-price-range__symbol" aria-hidden="true">$</span>
                    <input
                      type="number"
                      id="sdcl-pmin-{{ forloop.index }}"
                      class="sdcl-price-range__input"
                      name="{{ filter.min_value.param_name }}"
                      value="{{ filter.min_value.value | money_without_currency | remove: ',' }}"
                      min="{{ filter.range_min | money_without_currency | remove: ',' }}"
                      max="{{ filter.range_max | money_without_currency | remove: ',' }}"
                      placeholder="{{ filter.range_min | money_without_currency | remove: ',' }}"
                    >
                  </div>
                </div>
                <span class="sdcl-price-range__sep" aria-hidden="true">–</span>
                <div class="sdcl-price-range__field">
                  <label class="sdcl-price-range__label" for="sdcl-pmax-{{ forloop.index }}">Max</label>
                  <div class="sdcl-price-range__wrap">
                    <span class="sdcl-price-range__symbol" aria-hidden="true">$</span>
                    <input
                      type="number"
                      id="sdcl-pmax-{{ forloop.index }}"
                      class="sdcl-price-range__input"
                      name="{{ filter.max_value.param_name }}"
                      value="{{ filter.max_value.value | money_without_currency | remove: ',' }}"
                      min="{{ filter.range_min | money_without_currency | remove: ',' }}"
                      max="{{ filter.range_max | money_without_currency | remove: ',' }}"
                      placeholder="{{ filter.range_max | money_without_currency | remove: ',' }}"
                    >
                  </div>
                </div>
              </div>

              <button type="submit" class="sdcl-price-range__apply">Apply price</button>

              {%- if filter_has_active -%}
                <a href="{{ filter.url_to_remove }}" class="sdcl-price-range__reset">Reset</a>
              {%- endif -%}

            </form>
          {%- endif -%}

        </div>{%- comment -%} /.sdcl-accordion__body {%- endcomment -%}
      </div>{%- comment -%} /.sdcl-accordion {%- endcomment -%}

    {%- endfor -%}

  {%- else -%}
    <p class="sdcl-sidebar__empty">No filters available for this collection.</p>
  {%- endif -%}

</aside>{%- comment -%} /.sdcl-sidebar {%- endcomment -%}

