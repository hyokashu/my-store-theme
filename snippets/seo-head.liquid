{%- liquid
  assign site_name = settings.seo_site_name | default: 'Sprout Collects'

  if request.page_type == 'index'
    assign seo_title = page_title
  else
    assign seo_title = page_title | append: ' | ' | append: site_name
  endif

  if page_description != blank
    assign seo_description = page_description
  elsif request.page_type == 'product' and product.description != blank
    assign seo_description = product.description | strip_html | truncate: 155
  elsif request.page_type == 'collection' and collection.description != blank
    assign seo_description = collection.description | strip_html | truncate: 155
  else
    assign seo_description = settings.seo_site_description | default: "Australia's home for authentic Pokémon and One Piece TCG booster boxes, ETBs and singles."
  endif

  if request.page_type == 'product' and product.featured_image
    assign og_image = product.featured_image | image_url: width: 1200
  elsif request.page_type == 'collection' and collection.featured_image
    assign og_image = collection.featured_image | image_url: width: 1200
  elsif settings.seo_og_default_image != blank
    assign og_image = settings.seo_og_default_image | image_url: width: 1200
  else
    assign og_image = ''
  endif

  if request.page_type == 'product'
    assign og_type = 'product'
  else
    assign og_type = 'website'
  endif
-%}

<title>{{ seo_title }}</title>
<meta name="description" content="{{ seo_description | escape }}">

<meta property="og:site_name" content="{{ site_name | escape }}">
<meta property="og:title" content="{{ seo_title | escape }}">
<meta property="og:description" content="{{ seo_description | escape }}">
<meta property="og:url" content="{{ canonical_url }}">
<meta property="og:type" content="{{ og_type }}">
{%- if og_image != blank -%}
  <meta property="og:image" content="https:{{ og_image }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="{%- if request.page_type == 'product' -%}1200{%- else -%}630{%- endif -%}">
{%- endif -%}
<meta property="og:locale" content="{{ request.locale.iso_code | replace: '-', '_' }}">

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ seo_title | escape }}">
<meta name="twitter:description" content="{{ seo_description | escape }}">
{%- if og_image != blank -%}
  <meta name="twitter:image" content="https:{{ og_image }}">
{%- endif -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": {{ site_name | json }},
  "url": {{ shop.url | json }},
  "logo": {%- if settings.seo_org_logo != blank -%}{{ settings.seo_org_logo | image_url: width: 400 | prepend: 'https:' | json }}{%- else -%}null{%- endif -%},
  "contactPoint": {
    "@type": "ContactPoint",
    "contactType": "customer support",
    "email": {{ settings.seo_contact_email | default: 'support@sproutclc.com' | json }},
    "areaServed": "AU",
    "availableLanguage": "English"
  },
  "sameAs": [
    {%- assign social_urls = '' -%}
    {%- if settings.seo_social_instagram != blank -%}{%- assign social_urls = social_urls | append: settings.seo_social_instagram | append: '||' -%}{%- endif -%}
    {%- if settings.seo_social_tiktok != blank -%}{%- assign social_urls = social_urls | append: settings.seo_social_tiktok | append: '||' -%}{%- endif -%}
    {%- if settings.seo_social_youtube != blank -%}{%- assign social_urls = social_urls | append: settings.seo_social_youtube | append: '||' -%}{%- endif -%}
    {%- if settings.seo_social_facebook != blank -%}{%- assign social_urls = social_urls | append: settings.seo_social_facebook | append: '||' -%}{%- endif -%}
    {%- assign social_array = social_urls | split: '||' -%}
    {%- for url in social_array -%}
      {%- if url != blank -%}{{ url | json }}{%- unless forloop.last -%},{%- endunless -%}{%- endif -%}
    {%- endfor -%}
  ]
}
</script>

{%- if request.page_type == 'index' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": {{ site_name | json }},
  "url": {{ shop.url | json }},
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": {{ shop.url | append: '/search?q={search_term_string}' | json }}
    },
    "query-input": "required name=search_term_string"
  }
}
</script>
{%- endif -%}

{%- if request.page_type == 'product' or request.page_type == 'collection' -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": {{ shop.url | json }} }
    {%- if request.page_type == 'collection' -%}
    ,{ "@type": "ListItem", "position": 2, "name": {{ collection.title | json }}, "item": {{ shop.url | append: collection.url | json }} }
    {%- elsif request.page_type == 'product' -%}
      {%- if product.collections.first -%}
      ,{ "@type": "ListItem", "position": 2, "name": {{ product.collections.first.title | json }}, "item": {{ shop.url | append: product.collections.first.url | json }} }
      ,{ "@type": "ListItem", "position": 3, "name": {{ product.title | json }}, "item": {{ shop.url | append: product.url | json }} }
      {%- else -%}
      ,{ "@type": "ListItem", "position": 2, "name": {{ product.title | json }}, "item": {{ shop.url | append: product.url | json }} }
      {%- endif -%}
    {%- endif -%}
  ]
}
</script>
{%- endif -%}
