{% comment %}
  Sprout — sections/footer.liquid
  Multi-column trust-anchor footer.
  Background: deep slate/purple · Text: cream/off-white
  Columns: Brand | Customer Care | Business Address | Community
  All dynamic settings accessed by explicit ID (not bracket notation).
{% endcomment %}

{%- assign footer_logo_width = section.settings.footer_logo_width | default: 120 -%}
<footer class="sd-footer" role="contentinfo" aria-label="Site footer">
  <div class="sd-footer__inner">

    {%- comment -%} ── 1. Brand column ── {%- endcomment -%}
    <div class="sd-footer__col sd-footer__col--brand">
      <a href="{{ routes.root_url }}" class="sd-footer__brand-link" aria-label="{{ shop.name }}">
        {%- if section.settings.footer_logo != blank -%}
          <img
            src="{{ section.settings.footer_logo | image_url: width: 400 }}"
            alt="{{ shop.name }}"
            class="sd-footer__logo"
            loading="lazy"
          >
        {%- else -%}
          <span class="sd-footer__brand-name">{{ shop.name }}</span>
        {%- endif -%}
      </a>
      <p class="sd-footer__tagline">{{ section.settings.tagline | default: 'Your one-stop destination for sealed TCG products. Authentic. Affordable. Fast.' }}</p>
    </div>

    {%- comment -%} ── 2. Customer Care column (mobile accordion) ── {%- endcomment -%}
    <div class="sd-footer__col">
      <details class="sd-footer__accordion" open>
        <summary class="sd-footer__summary" aria-label="Customer Care">
          Customer Care
          <svg class="sd-footer__chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </summary>
        <div class="sd-footer__accordion-body">
          <ul class="sd-footer__list">

            {%- comment -%} Email {%- endcomment -%}
            <li class="sd-footer__list-item">
              <svg class="sd-footer__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <a href="mailto:{{ section.settings.support_email | default: 'support@sprout.com' }}" class="sd-footer__link">
                {{ section.settings.support_email | default: 'support@sprout.com' }}
              </a>
            </li>

            {%- comment -%} Phone {%- endcomment -%}
            {%- if section.settings.phone != blank -%}
              <li class="sd-footer__list-item">
                <svg class="sd-footer__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.4 2 2 0 0 1 3.58 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.25a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                <a href="tel:{{ section.settings.phone }}" class="sd-footer__link">{{ section.settings.phone }}</a>
              </li>
            {%- endif -%}

            {%- comment -%} Hours {%- endcomment -%}
            <li class="sd-footer__list-item">
              <svg class="sd-footer__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              <span class="sd-footer__text">{{ section.settings.hours | default: 'Mon–Fri: 9am – 5pm AEST' }}</span>
            </li>
          </ul>

          {%- comment -%} Quick links — explicit IDs, no bracket notation {%- endcomment -%}
          <ul class="sd-footer__links-list">
            {%- if section.settings.quick_link_1_label != blank -%}
              <li><a href="{{ section.settings.quick_link_1_url | default: '#' }}" class="sd-footer__link">{{ section.settings.quick_link_1_label }}</a></li>
            {%- endif -%}
            {%- if section.settings.quick_link_2_label != blank -%}
              <li><a href="{{ section.settings.quick_link_2_url | default: '#' }}" class="sd-footer__link">{{ section.settings.quick_link_2_label }}</a></li>
            {%- endif -%}
            {%- if section.settings.quick_link_3_label != blank -%}
              <li><a href="{{ section.settings.quick_link_3_url | default: '#' }}" class="sd-footer__link">{{ section.settings.quick_link_3_label }}</a></li>
            {%- endif -%}
            {%- if section.settings.quick_link_4_label != blank -%}
              <li><a href="{{ section.settings.quick_link_4_url | default: '#' }}" class="sd-footer__link">{{ section.settings.quick_link_4_label }}</a></li>
            {%- endif -%}
          </ul>
        </div>{%- comment -%} /.sd-footer__accordion-body {%- endcomment -%}
      </details>
    </div>

    {%- comment -%} ── 3. Business Address column (mobile accordion) ── {%- endcomment -%}
    <div class="sd-footer__col">
      <details class="sd-footer__accordion" open>
        <summary class="sd-footer__summary" aria-label="Our Location">
          Our Location
          <svg class="sd-footer__chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </summary>
        <div class="sd-footer__accordion-body">
          <address class="sd-footer__address">
            <svg class="sd-footer__icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            <span>
              {%- if section.settings.address != blank -%}
                {{ section.settings.address | newline_to_br }}
              {%- else -%}
                Sprout<br>
                123 Collector Way<br>
                Melbourne VIC 3000<br>
                Australia
              {%- endif -%}
            </span>
          </address>
          {%- if section.settings.abn != blank -%}
            <p class="sd-footer__abn">ABN: {{ section.settings.abn }}</p>
          {%- endif -%}
        </div>{%- comment -%} /.sd-footer__accordion-body {%- endcomment -%}
      </details>
    </div>

    {%- comment -%} ── 4. Community / Social column (mobile accordion) ── {%- endcomment -%}
    <div class="sd-footer__col">
      <details class="sd-footer__accordion" open>
        <summary class="sd-footer__summary" aria-label="Community">
          Community
          <svg class="sd-footer__chevron" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </summary>
        <div class="sd-footer__accordion-body">
          <p class="sd-footer__social-intro">{{ section.settings.social_intro | default: 'Follow us for drops, pulls & community events.' }}</p>
          <div class="sd-footer__socials">

            {%- if section.settings.instagram_url != blank -%}
              <a href="{{ section.settings.instagram_url }}" class="sd-footer__social-btn" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                <span>Instagram</span>
              </a>
            {%- endif -%}

            {%- if section.settings.discord_url != blank -%}
              <a href="{{ section.settings.discord_url }}" class="sd-footer__social-btn" aria-label="Discord" target="_blank" rel="noopener noreferrer">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.317 4.37a19.8 19.8 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03z"/></svg>
                <span>Discord</span>
              </a>
            {%- endif -%}

            {%- if section.settings.youtube_url != blank -%}
              <a href="{{ section.settings.youtube_url }}" class="sd-footer__social-btn" aria-label="YouTube" target="_blank" rel="noopener noreferrer">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" style="fill:currentColor;stroke:none"/></svg>
                <span>YouTube</span>
              </a>
            {%- endif -%}

            {%- if section.settings.tiktok_url != blank -%}
              <a href="{{ section.settings.tiktok_url }}" class="sd-footer__social-btn" aria-label="TikTok" target="_blank" rel="noopener noreferrer">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
                <span>TikTok</span>
              </a>
            {%- endif -%}

          </div>
        </div>{%- comment -%} /.sd-footer__accordion-body {%- endcomment -%}
      </details>
    </div>

  </div>{%- comment -%} /.sd-footer__inner {%- endcomment -%}

  {%- comment -%} ── Bottom bar ── {%- endcomment -%}
  <div class="sd-footer__bottom">
    <div class="sd-footer__bottom-inner">
      <p class="sd-footer__copy">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}.
        {{ section.settings.legal_note | default: 'All rights reserved.' }}
      </p>
      <nav class="sd-footer__legal-nav" aria-label="Legal links">
        {%- if section.settings.legal_link_1_label != blank -%}
          <a href="{{ section.settings.legal_link_1_url | default: '#' }}" class="sd-footer__legal-link">{{ section.settings.legal_link_1_label }}</a>
        {%- endif -%}
        {%- if section.settings.legal_link_2_label != blank -%}
          <a href="{{ section.settings.legal_link_2_url | default: '#' }}" class="sd-footer__legal-link">{{ section.settings.legal_link_2_label }}</a>
        {%- endif -%}
        {%- if section.settings.legal_link_3_label != blank -%}
          <a href="{{ section.settings.legal_link_3_url | default: '#' }}" class="sd-footer__legal-link">{{ section.settings.legal_link_3_label }}</a>
        {%- endif -%}
      </nav>
    </div>
  </div>

  <script>
    (function () {
      if (window.matchMedia('(max-width: 768px)').matches) {
        document.querySelectorAll('.sd-footer__accordion').forEach(function (el) {
          el.removeAttribute('open');
        });
      }
    })();
  </script>
</footer>

<style>
/* ============================================================
   Enchanted Forest — Footer
   Very dark green background (#0A160D) · aged parchment text · gilded gold accents
   ============================================================ */
:root {
  --sdf-bg:      #0A160D;
  --sdf-fg:      #FDFBF2;
  --sdf-muted:   rgba(253,251,242,0.65);
  --sdf-border:  rgba(253,251,242,0.12);
  --sdf-accent:  #C59B43;
  --sdf-radius:  1rem;
}

.sd-footer {
  background:   var(--sdf-bg);
  color:        var(--sdf-fg);
  font-family:  var(--cv-font-sans, 'Inter', system-ui, sans-serif);
  font-size:    0.9375rem;
  line-height:  1.6;
}

/* ── 4-column grid ── */
.sd-footer__inner {
  display:     grid;
  grid-template-columns: 1fr;
  gap:         2.5rem;
  max-width:   80rem;
  margin:      0 auto;
  padding:     3.5rem 1.5rem 3rem;
}
@media (min-width: 640px)  { .sd-footer__inner { grid-template-columns: 1fr 1fr; } }
@media (min-width: 1024px) { .sd-footer__inner { grid-template-columns: 1.6fr 1fr 1fr 1fr; gap: 3rem; } }

/* ── Brand ── */
.sd-footer__brand-link { text-decoration: none; display: inline-block; margin-bottom: 0.875rem; }
.sd-footer__logo       { max-width: {{ footer_logo_width }}px; width: 100%; height: auto; display: block; }
.sd-footer__brand-name {
  font-family:    var(--cv-font-head, 'Nunito', system-ui, sans-serif);
  font-size:      1.375rem; font-weight: 800;
  color:          var(--sdf-fg); letter-spacing: -0.02em;
  display:        block;
  margin-bottom:  0.875rem;
}
.sd-footer__tagline { font-size: 0.875rem; color: var(--sdf-muted); margin: 0; max-width: 22rem; }

/* ── Column heading ── */
.sd-footer__col-title {
  font-family:    var(--cv-font-head, 'Nunito', system-ui, sans-serif);
  font-size:      0.75rem; font-weight: 700;
  letter-spacing: 0.08em; text-transform: uppercase;
  color:          var(--sdf-muted);
  margin:         0 0 1rem;
  padding-bottom: 0.625rem;
  border-bottom:  1px solid var(--sdf-border);
}

/* ── List items ── */
.sd-footer__list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.625rem; }
.sd-footer__list-item { display: flex; align-items: center; gap: 0.5rem; font-size: 0.875rem; }
.sd-footer__icon { width: 1rem; height: 1rem; flex-shrink: 0; opacity: 0.7; }
.sd-footer__link { color: var(--sdf-fg); text-decoration: none; transition: color 0.15s; word-break: break-all; }
.sd-footer__link:hover { color: var(--sdf-accent); }
.sd-footer__text { color: var(--sdf-muted); font-size: 0.875rem; }

/* ── Quick links (no icons) ── */
.sd-footer__links-list {
  list-style: none; padding: 0; margin: 1rem 0 0;
  display: flex; flex-direction: column; gap: 0.375rem;
}
.sd-footer__links-list .sd-footer__link { font-size: 0.875rem; color: var(--sdf-muted); }
.sd-footer__links-list .sd-footer__link:hover { color: var(--sdf-fg); }

/* ── Address ── */
.sd-footer__address {
  font-style:  normal; font-size: 0.875rem; color: var(--sdf-muted);
  display:     flex; gap: 0.5rem; align-items: flex-start; line-height: 1.75;
}
.sd-footer__address .sd-footer__icon { margin-top: 0.225rem; }
.sd-footer__abn { font-size: 0.8125rem; color: var(--sdf-muted); margin-top: 0.75rem; }

/* ── Social ── */
.sd-footer__social-intro { font-size: 0.875rem; color: var(--sdf-muted); margin: 0 0 1rem; }
.sd-footer__socials      { display: flex; flex-direction: column; gap: 0.5rem; }
.sd-footer__social-btn {
  display:          inline-flex; align-items: center; gap: 0.625rem;
  text-decoration:  none; color: var(--sdf-fg);
  font-size:        0.875rem; font-weight: 500;
  padding:          0.5rem 0.75rem;
  border:           1px solid var(--sdf-border);
  border-radius:    var(--sdf-radius);
  width:            fit-content;
  transition:       background 0.15s, border-color 0.15s, color 0.15s;
}
.sd-footer__social-btn:hover { background: rgba(255,255,255,0.07); border-color: var(--sdf-accent); color: var(--sdf-accent); }
.sd-footer__social-btn svg   { width: 1.125rem; height: 1.125rem; }

/* ── Bottom bar ── */
.sd-footer__bottom { border-top: 1px solid var(--sdf-border); padding: 1rem 1.5rem; }
.sd-footer__bottom-inner {
  max-width: 80rem; margin: 0 auto;
  display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem;
}
.sd-footer__copy { font-size: 0.8125rem; color: var(--sdf-muted); margin: 0; }
.sd-footer__legal-nav  { display: flex; gap: 1rem; flex-wrap: wrap; }
.sd-footer__legal-link { font-size: 0.8125rem; color: var(--sdf-muted); text-decoration: none; transition: color 0.15s; }
.sd-footer__legal-link:hover { color: var(--sdf-fg); }

/* ── Footer Accordion — <details>/<summary> ──────────────────
   Desktop (≥769px): content always visible; summary styled as
   a plain heading with pointer-events off so it can't toggle.
   Mobile (<769px):  native browser accordion; chevron rotates
   on open; body hidden until <details open> is set.
   ──────────────────────────────────────────────────────────── */

/* Remove the native browser disclosure triangle on all browsers */
.sd-footer__accordion > summary { list-style: none; }
.sd-footer__accordion > summary::-webkit-details-marker { display: none; }

/* ── Desktop: always-expanded, looks identical to original columns ── */
@media (min-width: 769px) {
  .sd-footer__summary {
    /* Inherit all col-title visual styles */
    display:        block;
    font-family:    var(--cv-font-head, 'Nunito', system-ui, sans-serif);
    font-size:      0.75rem;
    font-weight:    700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color:          var(--sdf-muted);
    margin:         0 0 1rem;
    padding-bottom: 0.625rem;
    border-bottom:  1px solid var(--sdf-border);
    /* Disable toggle behaviour */
    pointer-events: none;
    cursor:         default;
  }

  /* Chevron is desktop-irrelevant — hide it */
  .sd-footer__chevron { display: none; }

  /* Body always visible on desktop regardless of [open] state */
  .sd-footer__accordion-body { display: block !important; }
}

/* ── Mobile: collapsible accordion ── */
@media (max-width: 768px) {
  /* details wrapper — full-width row with border separator */
  .sd-footer__accordion {
    border-bottom: 1px solid var(--sdf-border);
  }

  /* summary = the tappable header row */
  .sd-footer__summary {
    display:         flex;
    align-items:     center;
    justify-content: space-between;
    width:           100%;
    padding:         0.875rem 0;
    cursor:          pointer;
    font-family:     var(--cv-font-head, 'Nunito', system-ui, sans-serif);
    font-size:       0.875rem;
    font-weight:     700;
    color:           var(--sdf-fg);
    user-select:     none;
    -webkit-tap-highlight-color: transparent;
  }

  .sd-footer__summary:hover { color: var(--sdf-accent); }

  /* Chevron rotates 180° when open */
  .sd-footer__chevron {
    flex-shrink: 0;
    opacity:     0.7;
    transition:  transform 0.22s ease;
    color:       var(--sdf-muted);
  }
  .sd-footer__accordion[open] .sd-footer__chevron {
    transform: rotate(180deg);
    opacity:   1;
    color:     var(--sdf-accent);
  }

  /* Body: visible only when details is open (browser native) */
  .sd-footer__accordion-body {
    padding-bottom: 1rem;
  }

  /* Remove top border on each inner list (no longer needed under accordion) */
  .sd-footer__accordion .sd-footer__col-title { display: none; }
}
</style>

{% schema %}
{
  "name": "Footer",
  "tag": "div",
  "class": "sd-footer-wrap",
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Footer logo",
      "info": "Recommended: white/transparent PNG"
    },
    {
      "type": "range",
      "id": "footer_logo_width",
      "label": "Logo size",
      "min": 60,
      "max": 300,
      "step": 10,
      "default": 120,
      "unit": "px"
    },
    {
      "type": "text",
      "id": "tagline",
      "label": "Brand tagline",
      "default": "Your one-stop destination for sealed TCG products. Authentic. Affordable. Fast."
    },
    {
      "type": "header",
      "content": "Customer Care"
    },
    {
      "type": "text",
      "id": "support_email",
      "label": "Support email",
      "default": "support@sprout.com"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number",
      "default": "+61 3 0000 0000"
    },
    {
      "type": "text",
      "id": "hours",
      "label": "Operating hours",
      "default": "Mon–Fri: 9am – 5pm AEST"
    },
    {
      "type": "header",
      "content": "Quick Links"
    },
    {
      "type": "text",
      "id": "quick_link_1_label",
      "label": "Quick link 1 — label",
      "default": "FAQ"
    },
    {
      "type": "url",
      "id": "quick_link_1_url",
      "label": "Quick link 1 — URL"
    },
    {
      "type": "text",
      "id": "quick_link_2_label",
      "label": "Quick link 2 — label",
      "default": "Shipping & Returns"
    },
    {
      "type": "url",
      "id": "quick_link_2_url",
      "label": "Quick link 2 — URL"
    },
    {
      "type": "text",
      "id": "quick_link_3_label",
      "label": "Quick link 3 — label",
      "default": "Track My Order"
    },
    {
      "type": "url",
