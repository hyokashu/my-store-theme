{% comment %}
  CardVault — main-home.liquid
  Gameology-inspired homepage. Fully self-contained CSS + JS.
  Shares the CardVault design tokens established in main-product.liquid.
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700;800&display=swap" rel="stylesheet">

<style>
/* =============================================================
   CardVault Design Tokens (shared with product page)
   ============================================================= */
:root {
  --cv-bg:         #f7f6f3;
  --cv-fg:         #1c1f36;
  --cv-card:       #ffffff;
  --cv-primary:    #282d52;
  --cv-primary-fg: #f8f7f5;
  --cv-secondary:  #eeecea;
  --cv-muted-fg:   #76798c;
  --cv-border:     #dedad5;
  --cv-destructive:#c94030;
  --cv-success:    #2e9963;
  --cv-success-fg: #f8f7f5;
  --cv-star:       #d4783a;
  --cv-radius:     0.5rem;
  --cv-shadow-sm:  0 1px 2px rgba(0,0,0,0.05);
  --cv-shadow:     0 1px 3px rgba(0,0,0,0.07), 0 1px 2px rgba(0,0,0,0.05);
  --cv-font-sans:  'Inter', system-ui, -apple-system, sans-serif;
  --cv-font-head:  'Space Grotesk', system-ui, sans-serif;
}

/* =============================================================
   Home Page Base
   ============================================================= */
.cvh * { box-sizing: border-box; }
.cvh {
  font-family: var(--cv-font-sans);
  color: var(--cv-fg);
  background: var(--cv-bg);
}
.cvh a { text-decoration: none; color: inherit; }
.cvh img { display: block; max-width: 100%; }

.cvh__inner {
  max-width: 80rem;
  margin: 0 auto;
  padding-left: 1rem;
  padding-right: 1rem;
}
@media (min-width: 1024px) {
  .cvh__inner { padding-left: 2rem; padding-right: 2rem; }
}

/* =============================================================
   Shared Button
   ============================================================= */
.cvh-btn {
  display: inline-flex; align-items: center; justify-content: center;
  gap: 0.5rem;
  font-family: var(--cv-font-sans);
  font-size: 0.9375rem; font-weight: 600;
  border-radius: var(--cv-radius);
  border: 1px solid transparent;
  cursor: pointer; text-decoration: none;
  padding: 0 1.5rem;
  height: 2.875rem;
  transition: opacity 0.15s, background 0.15s, transform 0.15s;
  white-space: nowrap;
  -webkit-appearance: none;
}
.cvh-btn:hover   { opacity: 0.88; transform: translateY(-1px); }
.cvh-btn:active  { transform: translateY(0); }

.cvh-btn--primary {
  background: var(--cv-primary); color: var(--cv-primary-fg);
  border-color: var(--cv-primary);
}
.cvh-btn--outline {
  background: transparent;
  border-color: var(--cv-primary); color: var(--cv-primary);
}
.cvh-btn--outline:hover { background: rgba(40,45,82,0.06); }
.cvh-btn--white {
  background: #fff; color: var(--cv-primary);
  border-color: #fff;
}
.cvh-btn--ghost {
  background: transparent; color: var(--cv-primary-fg);
  border-color: rgba(255,255,255,0.5);
}
.cvh-btn--ghost:hover { background: rgba(255,255,255,0.12); }
.cvh-btn svg { width: 1rem; height: 1rem; flex-shrink: 0; }
.cvh-btn--sm { height: 2.25rem; font-size: 0.8125rem; padding: 0 1rem; }

/* Section headers */
.cvh-section-hd { display: flex; flex-direction: column; gap: 0.375rem; margin-bottom: 1.75rem; }
.cvh-section-hd--row { flex-direction: row; align-items: flex-end; justify-content: space-between; gap: 1rem; flex-wrap: wrap; }
.cvh-section-title {
  font-family: var(--cv-font-head);
  font-size: 1.75rem; font-weight: 700;
  letter-spacing: -0.02em; line-height: 1.15;
}
@media (min-width: 768px) { .cvh-section-title { font-size: 2.25rem; } }
.cvh-section-sub { font-size: 0.9375rem; color: var(--cv-muted-fg); }

/* =============================================================
   1. HERO SLIDER
   ============================================================= */
.cvh-hero {
  position: relative;
  overflow: hidden;
  background: var(--cv-card);
  border-bottom: 1px solid var(--cv-border);
}

.cvh-hero__track {
  display: flex;
  transition: transform 0.55s cubic-bezier(0.4,0,0.2,1);
}

.cvh-hero__slide {
  min-width: 100%;
  display: grid;
  grid-template-columns: 1fr;
  align-items: center;
  gap: 0;
  padding: 3rem 1rem 2rem;
}
@media (min-width: 768px) {
  .cvh-hero__slide {
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    padding: 4rem 2rem;
    min-height: 520px;
  }
}
@media (min-width: 1024px) {
  .cvh-hero__slide {
    padding: 5rem 2rem;
    min-height: 560px;
    max-width: 80rem;
    margin: 0 auto;
  }
}

/* Slide wrapper for full-bleed background */
.cvh-hero__slide-wrap {
  min-width: 100%;
  position: relative;
}
.cvh-hero__slide-wrap::before {
  content: '';
  position: absolute; inset: 0;
  z-index: 0;
}
.cvh-hero__slide-wrap--1::before { background: linear-gradient(135deg, #f0edf8 0%, #e8e4f5 100%); }
.cvh-hero__slide-wrap--2::before { background: linear-gradient(135deg, #e8f5ed 0%, #d4eedd 100%); }
.cvh-hero__slide-wrap--3::before { background: linear-gradient(135deg, #fdf0e8 0%, #f5e0cc 100%); }

.cvh-hero__slide-wrap > .cvh-hero__slide { position: relative; z-index: 1; max-width: 80rem; margin: 0 auto; }

.cvh-hero__text { display: flex; flex-direction: column; gap: 1.25rem; }
.cvh-hero__eyebrow {
  display: inline-flex; align-items: center; gap: 0.375rem;
  background: rgba(40,45,82,0.08);
  color: var(--cv-primary);
  font-size: 0.8125rem; font-weight: 600; letter-spacing: 0.04em; text-transform: uppercase;
  padding: 0.375rem 0.75rem;
  border-radius: 9999px;
  width: fit-content;
}
.cvh-hero__eyebrow svg { width: 0.875rem; height: 0.875rem; }
.cvh-hero__title {
  font-family: var(--cv-font-head);
  font-size: 2.5rem; font-weight: 800;
  line-height: 1.1; letter-spacing: -0.03em;
  color: var(--cv-fg);
}
@media (min-width: 768px)  { .cvh-hero__title { font-size: 3rem; } }
@media (min-width: 1024px) { .cvh-hero__title { font-size: 3.5rem; } }
.cvh-hero__title em { font-style: normal; color: var(--cv-primary); }

.cvh-hero__desc { font-size: 1rem; line-height: 1.65; color: var(--cv-muted-fg); max-width: 32rem; }

.cvh-hero__ctas { display: flex; gap: 0.75rem; flex-wrap: wrap; }

.cvh-hero__img-wrap {
  display: none;
  position: relative;
  border-radius: calc(var(--cv-radius) * 3);
  overflow: hidden;
  aspect-ratio: 1 / 1;
  box-shadow: 0 20px 60px rgba(0,0,0,0.12);
}
@media (min-width: 768px) { .cvh-hero__img-wrap { display: block; } }
.cvh-hero__img-wrap img { width: 100%; height: 100%; object-fit: cover; }

/* Floating badge on hero image */
.cvh-hero__badge {
  position: absolute;
  bottom: 1.25rem; left: 1.25rem;
  background: rgba(255,255,255,0.95);
  backdrop-filter: blur(8px);
  border: 1px solid var(--cv-border);
  border-radius: calc(var(--cv-radius) * 1.5);
  padding: 0.75rem 1rem;
  box-shadow: var(--cv-shadow);
  display: flex; align-items: center; gap: 0.75rem;
}
.cvh-hero__badge-icon {
  width: 2.5rem; height: 2.5rem;
  border-radius: var(--cv-radius);
  background: var(--cv-primary);
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}
.cvh-hero__badge-icon svg { width: 1.25rem; height: 1.25rem; color: #fff; }
.cvh-hero__badge-text { display: flex; flex-direction: column; }
.cvh-hero__badge-val  { font-family: var(--cv-font-head); font-size: 1.125rem; font-weight: 700; }
.cvh-hero__badge-label { font-size: 0.75rem; color: var(--cv-muted-fg); }

/* Slider controls */
.cvh-hero__controls {
  position: absolute;
  bottom: 1.5rem; left: 50%; transform: translateX(-50%);
  display: flex; align-items: center; gap: 0.75rem;
  z-index: 10;
}
.cvh-hero__dot {
  width: 0.5rem; height: 0.5rem;
  border-radius: 9999px;
  background: rgba(40,45,82,0.25);
  border: none; cursor: pointer; padding: 0;
  transition: background 0.2s, width 0.2s;
}
.cvh-hero__dot.is-active { background: var(--cv-primary); width: 1.5rem; }

.cvh-hero__arrow {
  position: absolute;
  top: 50%; transform: translateY(-50%);
  width: 2.5rem; height: 2.5rem;
  border-radius: 9999px;
  background: rgba(255,255,255,0.9);
  border: 1px solid var(--cv-border);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  box-shadow: var(--cv-shadow);
  z-index: 10;
  color: var(--cv-fg);
  transition: background 0.15s;
  -webkit-appearance: none;
}
.cvh-hero__arrow:hover { background: #fff; }
.cvh-hero__arrow svg { width: 1.25rem; height: 1.25rem; }
.cvh-hero__arrow--prev { left: 1rem; }
.cvh-hero__arrow--next { right: 1rem; }
@media (min-width: 768px) {
  .cvh-hero__arrow--prev { left: 1.5rem; }
  .cvh-hero__arrow--next { right: 1.5rem; }
}

/* =============================================================
   2. TRUST BAR
   ============================================================= */
.cvh-trust-bar {
  background: var(--cv-primary);
  color: var(--cv-primary-fg);
  padding: 1.75rem 1rem;
}
.cvh-trust-bar__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
  max-width: 80rem; margin: 0 auto;
}
@media (min-width: 768px) { .cvh-trust-bar__grid { grid-template-columns: repeat(4, 1fr); gap: 2rem; padding: 0 2rem; } }

.cvh-trust-item {
  display: flex; align-items: flex-start; gap: 0.875rem;
}
.cvh-trust-item__icon {
  flex-shrink: 0;
  width: 2.5rem; height: 2.5rem;
  background: rgba(255,255,255,0.1);
  border-radius: var(--cv-radius);
  display: flex; align-items: center; justify-content: center;
}
.cvh-trust-item__icon svg { width: 1.25rem; height: 1.25rem; color: rgba(255,255,255,0.9); }
.cvh-trust-item__text { display: flex; flex-direction: column; gap: 0.2rem; }
.cvh-trust-item__title { font-size: 0.9375rem; font-weight: 700; color: rgba(255,255,255,0.95); }
.cvh-trust-item__desc  { font-size: 0.8125rem; color: rgba(255,255,255,0.6); line-height: 1.5; }

/* =============================================================
   3. FAN FAVOURITES (tabbed product carousel)
   ============================================================= */
.cvh-featured { padding: 4rem 0; }

.cvh-featured__tabs {
  display: flex; gap: 0.5rem; flex-wrap: wrap;
  margin-bottom: 2rem;
}
.cvh-featured__tab {
  font-family: var(--cv-font-sans);
  font-size: 0.8125rem; font-weight: 600;
  letter-spacing: 0.04em; text-transform: uppercase;
  padding: 0.5rem 1.25rem;
  border: 1px solid var(--cv-border);
  border-radius: 9999px;
  background: var(--cv-card);
  color: var(--cv-muted-fg);
  cursor: pointer;
  transition: background 0.15s, border-color 0.15s, color 0.15s;
  -webkit-appearance: none;
}
.cvh-featured__tab.is-active,
.cvh-featured__tab:hover {
  background: var(--cv-primary); color: var(--cv-primary-fg); border-color: var(--cv-primary);
}

/* Scroll container */
.cvh-featured__scroll-wrap { position: relative; }
.cvh-featured__scroll {
  display: flex;
  gap: 1rem;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scrollbar-width: none;
  -ms-overflow-style: none;
  padding-bottom: 0.5rem;
}
.cvh-featured__scroll::-webkit-scrollbar { display: none; }

.cvh-featured__panel { display: none; }
.cvh-featured__panel.is-active { display: block; }

/* Product card (homepage version) */
.cvh-prod-card {
  scroll-snap-align: start;
  flex-shrink: 0;
  width: calc(50vw - 1.5rem);
  max-width: 14rem;
  display: flex; flex-direction: column; gap: 0.75rem;
  border: 1px solid var(--cv-border);
  border-radius: calc(var(--cv-radius) * 2);
  background: var(--cv-card);
  padding: 0.75rem;
  box-shadow: var(--cv-shadow-sm);
  transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  text-decoration: none; color: inherit;
}
@media (min-width: 640px)  { .cvh-prod-card { width: 13rem; max-width: 13rem; } }
@media (min-width: 1024px) { .cvh-prod-card { width: 14.5rem; max-width: 14.5rem; } }
.cvh-prod-card:hover {
  border-color: rgba(40,45,82,0.25);
  box-shadow: 0 6px 20px rgba(0,0,0,0.09);
  transform: translateY(-2px);
}
.cvh-prod-card__img {
  position: relative;
  aspect-ratio: 1 / 1;
  overflow: hidden;
  border-radius: var(--cv-radius);
  background: var(--cv-secondary);
}
.cvh-prod-card__img img {
  width: 100%; height: 100%; object-fit: cover;
  transition: transform 0.35s;
}
.cvh-prod-card:hover .cvh-prod-card__img img { transform: scale(1.06); }

.cvh-prod-card__badges {
  position: absolute; top: 0.5rem; left: 0.5rem;
  display: flex; flex-direction: column; gap: 0.25rem;
}
.cvh-prod-badge {
  font-size: 0.625rem; font-weight: 700;
  padding: 0.125rem 0.4rem;
  border-radius: calc(var(--cv-radius) - 2px);
  display: inline-block; line-height: 1.6;
}
.cvh-prod-badge--sale    { background: var(--cv-success);     color: var(--cv-success-fg); }
.cvh-prod-badge--new     { background: var(--cv-primary);     color: var(--cv-primary-fg); }
.cvh-prod-badge--preorder { background: var(--cv-destructive); color: #fff; }
.cvh-prod-badge--hot     { background: var(--cv-star);         color: #fff; }

.cvh-prod-card__info  { display: flex; flex-direction: column; gap: 0.25rem; }
.cvh-prod-card__type  { font-size: 0.6875rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--cv-muted-fg); font-weight: 600; }
.cvh-prod-card__name  { font-size: 0.875rem; font-weight: 600; line-height: 1.35; }
.cvh-prod-card__prices { display: flex; align-items: baseline; gap: 0.4rem; margin-top: 0.25rem; }
.cvh-prod-card__price {
  font-family: var(--cv-font-head); font-size: 1.0625rem; font-weight: 700;
}
.cvh-prod-card__was   { font-size: 0.75rem; color: var(--cv-muted-fg); text-decoration: line-through; }

/* Scroll nav arrows */
.cvh-scroll-arrow {
  display: none;
  position: absolute; top: 50%; transform: translateY(-50%);
  width: 2.5rem; height: 2.5rem; border-radius: 9999px;
  background: var(--cv-card); border: 1px solid var(--cv-border);
  box-shadow: var(--cv-shadow);
  align-items: center; justify-content: center;
  cursor: pointer; z-index: 5; color: var(--cv-fg);
  transition: background 0.15s;
  -webkit-appearance: none;
}
@media (min-width: 768px) { .cvh-scroll-arrow { display: flex; } }
.cvh-scroll-arrow:hover { background: var(--cv-secondary); }
.cvh-scroll-arrow svg   { width: 1.25rem; height: 1.25rem; }
.cvh-scroll-arrow--prev { left: -1.25rem; }
.cvh-scroll-arrow--next { right: -1.25rem; }

/* =============================================================
   4. MARQUEE TICKER
   ============================================================= */
.cvh-marquee {
  background: var(--cv-primary);
  padding: 0.875rem 0;
  overflow: hidden;
  white-space: nowrap;
}
.cvh-marquee__track {
  display: inline-flex; gap: 0;
  animation: cvhMarquee 28s linear infinite;
}
.cvh-marquee__track:hover { animation-play-state: paused; }
@keyframes cvhMarquee {
  from { transform: translateX(0); }
  to   { transform: translateX(-50%); }
}
.cvh-marquee__item {
  display: inline-flex; align-items: center; gap: 0.75rem;
  font-family: var(--cv-font-head);
  font-size: 0.875rem; font-weight: 600; letter-spacing: 0.04em;
  color: rgba(255,255,255,0.9);
  padding: 0 2rem;
}
.cvh-marquee__item svg  { width: 1rem; height: 1rem; color: rgba(255,255,255,0.5); }
.cvh-marquee__sep { color: rgba(255,255,255,0.3); font-size: 1.25rem; padding: 0 0.5rem; }

/* =============================================================
   5. BROWSE BY CATEGORY
   ============================================================= */
.cvh-categories { padding: 4rem 0; }

.cvh-cat-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0.75rem;
}
@media (min-width: 480px) { .cvh-cat-grid { grid-template-columns: repeat(3, 1fr); } }
@media (min-width: 768px) { .cvh-cat-grid { grid-template-columns: repeat(6, 1fr); gap: 1rem; } }

.cvh-cat-card {
  display: flex; flex-direction: column; align-items: center; gap: 0.875rem;
  padding: 1.25rem 0.75rem;
  border: 1px solid var(--cv-border);
  border-radius: calc(var(--cv-radius) * 2);
  background: var(--cv-card);
  box-shadow: var(--cv-shadow-sm);
  text-decoration: none; color: inherit;
  transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  text-align: center;
}
.cvh-cat-card:hover {
  border-color: var(--cv-primary);
  box-shadow: 0 4px 16px rgba(40,45,82,0.12);
  transform: translateY(-3px);
}
.cvh-cat-card__icon {
  width: 3.5rem; height: 3.5rem;
  border-radius: calc(var(--cv-radius) * 1.5);
  background: var(--cv-secondary);
  display: flex; align-items: center; justify-content: center;
  transition: background 0.2s;
}
.cvh-cat-card:hover .cvh-cat-card__icon { background: rgba(40,45,82,0.08); }
.cvh-cat-card__icon svg { width: 1.75rem; height: 1.75rem; color: var(--cv-primary); }
.cvh-cat-card__label {
  font-size: 0.8125rem; font-weight: 700;
  letter-spacing: 0.02em;
  line-height: 1.3;
}

/* Sale category — accent style */
.cvh-cat-card--sale { border-color: rgba(201,64,48,0.2); }
.cvh-cat-card--sale .cvh-cat-card__icon { background: rgba(201,64,48,0.08); }
.cvh-cat-card--sale .cvh-cat-card__icon svg { color: var(--cv-destructive); }
.cvh-cat-card--sale .cvh-cat-card__label { color: var(--cv-destructive); }
.cvh-cat-card--sale:hover { border-color: var(--cv-destructive); box-shadow: 0 4px 16px rgba(201,64,48,0.12); }

/* =============================================================
   6. PROMOTIONAL BANNERS (2-up)
   ============================================================= */
.cvh-promo { padding: 2rem 0 4rem; }
.cvh-promo__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1rem;
}
@media (min-width: 768px) { .cvh-promo__grid { grid-template-columns: 1fr 1fr; gap: 1.25rem; } }

.cvh-promo-card {
  position: relative;
  overflow: hidden;
  border-radius: calc(var(--cv-radius) * 2.5);
  min-height: 240px;
  display: flex; align-items: flex-end;
  padding: 2rem;
  text-decoration: none;
  background: var(--cv-primary);
}
@media (min-width: 768px) { .cvh-promo-card { min-height: 300px; } }

.cvh-promo-card__bg {
  position: absolute; inset: 0; z-index: 0;
}
.cvh-promo-card__bg img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; }
.cvh-promo-card:hover .cvh-promo-card__bg img { transform: scale(1.04); }

/* Gradient overlay */
.cvh-promo-card::after {
  content: '';
  position: absolute; inset: 0; z-index: 1;
  background: linear-gradient(to top, rgba(20,20,40,0.82) 0%, rgba(20,20,40,0.25) 55%, transparent 100%);
}
.cvh-promo-card__content { position: relative; z-index: 2; display: flex; flex-direction: column; gap: 0.75rem; }
.cvh-promo-card__eyebrow { font-size: 0.75rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(255,255,255,0.65); }
.cvh-promo-card__title {
  font-family: var(--cv-font-head);
  font-size: 1.625rem; font-weight: 800;
  color: #fff; line-height: 1.15; letter-spacing: -0.02em;
}
@media (min-width: 768px) { .cvh-promo-card__title { font-size: 2rem; } }
.cvh-promo-card__cta {
  display: inline-flex; align-items: center; gap: 0.375rem;
  font-size: 0.875rem; font-weight: 600;
  color: #fff;
  border-bottom: 1px solid rgba(255,255,255,0.5);
  padding-bottom: 0.125rem;
  transition: border-color 0.15s;
  width: fit-content;
}
.cvh-promo-card__cta:hover { border-color: #fff; }
.cvh-promo-card__cta svg { width: 0.875rem; height: 0.875rem; }

/* =============================================================
   7. ABOUT SECTION
   ============================================================= */
.cvh-about { padding: 4rem 0; background: var(--cv-card); }
.cvh-about__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2.5rem;
  align-items: center;
}
@media (min-width: 768px) { .cvh-about__grid { grid-template-columns: 1fr 1fr; gap: 4rem; } }

.cvh-about__img {
  border-radius: calc(var(--cv-radius) * 3);
  overflow: hidden;
  aspect-ratio: 4 / 3;
  box-shadow: 0 20px 60px rgba(0,0,0,0.1);
}
.cvh-about__img img { width: 100%; height: 100%; object-fit: cover; }

.cvh-about__text { display: flex; flex-direction: column; gap: 1.25rem; }
.cvh-about__title {
  font-family: var(--cv-font-head);
  font-size: 2.25rem; font-weight: 800;
  letter-spacing: -0.03em; line-height: 1.1;
