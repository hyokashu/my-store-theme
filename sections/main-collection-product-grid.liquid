{% comment %}
  Supply District — sections/main-collection-product-grid.liquid
  Paginated product grid for collection pages.
  Renders sd-product-card for each product.
  Can be used as a standalone section in a collection.json template.

  Grid layout:
  • Mobile: 2 columns (strictly)
  • Tablet (≥640px): 3 columns
  • Desktop (≥1024px): 4 columns

  Relies on:
  • assets/sd-collection.css — styles
  • assets/sd-collection.js — Quick Add + filter JS
  • snippets/sd-product-card.liquid — product card
{% endcomment %}

{{ 'sd-collection.css' | asset_url | stylesheet_tag }}
<script src="{{ 'sd-collection.js' | asset_url }}" defer></script>

{%- liquid
  assign products_per_page = section.settings.products_per_page | default: 24
-%}

{%- paginate collection.products by products_per_page -%}

<section class="sdcpg" aria-label="Products">
  <div class="sdcpg__inner">

    {%- comment -%} ── Top bar: count ── {%- endcomment -%}
    <div class="sdcpg__topbar">
      <p class="sdcpg__count">
        {%- if collection.products_count == 0 -%}
          No products
        {%- elsif collection.products_count == 1 -%}
          1 product
        {%- else -%}
          {{ collection.products_count }} products
        {%- endif -%}
      </p>
    </div>

    {%- if collection.products.size > 0 -%}

      <div class="sdcpg__grid">
        {%- for product in collection.products -%}
          {%- render 'sd-product-card', product: product -%}
        {%- endfor -%}
      </div>

      {%- comment -%} ── Pagination ── {%- endcomment -%}
      {%- if paginate.pages > 1 -%}
        <nav class="sdcpg__pagination" aria-label="Collection pagination">

          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="sdcpg__page-link" aria-label="Previous page">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2.5"
                stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="m15 18-6-6 6-6"/>
              </svg>
            </a>
          {%- endif -%}

          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}" class="sdcpg__page-link">{{ part.title }}</a>
            {%- elsif part.title == paginate.current_page -%}
              <span class="sdcpg__page-current" aria-current="page">{{ part.title }}</span>
            {%- else -%}
              <span class="sdcpg__page-dots">{{ part.title }}</span>
            {%- endif -%}
          {%- endfor -%}

          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="sdcpg__page-link" aria-label="Next page">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2.5"
                stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="m9 18 6-6-6-6"/>
              </svg>
            </a>
          {%- endif -%}

        </nav>
      {%- endif -%}

    {%- else -%}

      {%- comment -%} ── Empty state ── {%- endcomment -%}
      <div class="sdcpg__empty">
        <svg class="sdcpg__empty-icon" width="56" height="56" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="1.5"
          stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          <line x1="8" y1="11" x2="14" y2="11"/>
        </svg>
        <h2 class="sdcpg__empty-title">No products found</h2>
        <p class="sdcpg__empty-text">
          Try adjusting or clearing your filters, or browse all products.
        </p>
        <a href="{{ collection.url | split: '?' | first }}"
          style="
            display:inline-flex;align-items:center;margin-top:1.25rem;
            padding:0.65rem 1.5rem;border-radius:999px;
            background:var(--cv-primary);color:var(--cv-primary-fg);
            font-weight:600;font-size:0.875rem;text-decoration:none;
            transition:opacity 0.15s;">
          Clear all filters
        </a>
      </div>

    {%- endif -%}

  </div>
</section>

{%- endpaginate -%}

{% schema %}
{
  "name": "Collection Product Grid",
  "tag": "div",
  "class": "sd-collection-grid",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Collection Product Grid"
    }
  ]
}
{% endschema %}
