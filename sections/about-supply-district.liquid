{% comment %}
  Supply District — sections/about-supply-district.liquid
  ─────────────────────────────────────────────────────────
  50/50 brand story split-section for the homepage.
  · Image side: Shopify image_picker with optional floating badge
  · Text side: eyebrow (muted, NOT green) · H2 · green divider line ·
               richtext body · outline CTA button
  · Image position: left or right (schema select, reversible)
  · Von Restorff: green ONLY on the 3px divider line accent (subtle) — NOT on eyebrow
  · CTA: outline style, --cv-primary border + text (NOT green)
  · Schema: image, image_position, image_badge, eyebrow, heading, body, btn_text, btn_url
{% endcomment %}

{%- liquid
  assign img            = section.settings.image
  assign img_position   = section.settings.image_position | default: 'left'
  assign img_badge      = section.settings.image_badge
  assign eyebrow        = section.settings.eyebrow
  assign heading        = section.settings.heading
  assign body_content   = section.settings.body
  assign btn_text       = section.settings.btn_text
  assign btn_url        = section.settings.btn_url
  assign reverse_layout = false
  if img_position == 'right'
    assign reverse_layout = true
  endif
-%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@600;700;800&display=swap" rel="stylesheet">

<style>
  /* ── Design Tokens ── */
  .hasd-section {
    --cv-bg:                #f7f6f3;
    --cv-fg:                #1c1f36;
    --cv-primary:           #282d52;
    --cv-card:              #ffffff;
    --cv-secondary:         #eeecea;
    --cv-muted-fg:          #76798c;
    --cv-border:            #dedad5;
    --cv-radius:            0.5rem;
    --color-cta-primary:    #2e9963;
    --color-cta-primary-hv: #25834f;
    --cv-font-sans:         'Inter', sans-serif;
    --cv-font-head:         'Space Grotesk', sans-serif;
  }

  /* ── Section shell ── */
  .hasd-section {
    background: var(--cv-bg);
    padding: 5rem 1.5rem;
  }

  /* ── Grid: 50/50 ── */
  .hasd-inner {
    max-width: 80rem;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }

  /* ── Reverse layout (image right) ── */
  {%- if reverse_layout -%}
  .hasd-image-col  { order: 2; }
  .hasd-text-col   { order: 1; }
  {%- else -%}
  .hasd-image-col  { order: 1; }
  .hasd-text-col   { order: 2; }
  {%- endif -%}

  /* ── Image column ── */
  .hasd-image-col {
    position: relative;
  }

  .hasd-image-wrap {
    position: relative;
    border-radius: calc(var(--cv-radius) * 2);
    overflow: hidden;
    aspect-ratio: 4 / 5;
    background: var(--cv-secondary);
  }

  .hasd-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.55s ease;
  }
  .hasd-image-wrap:hover img {
    transform: scale(1.025);
  }

  /* ── Floating badge ── */
  .hasd-badge {
    position: absolute;
    {%- if reverse_layout -%}
    bottom: 1.5rem;
    left: 1.5rem;
    {%- else -%}
    bottom: 1.5rem;
    right: 1.5rem;
    {%- endif -%}
    background: var(--cv-card);
    border: 1px solid var(--cv-border);
    border-radius: var(--cv-radius);
    padding: 0.625rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    box-shadow: 0 4px 16px rgba(28, 31, 54, 0.12);
    z-index: 2;
  }

  .hasd-badge__pin {
    color: var(--cv-primary);
    flex-shrink: 0;
  }

  .hasd-badge__text {
    font-family: var(--cv-font-head);
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--cv-fg);
    white-space: nowrap;
  }

  /* ── Text column ── */
  .hasd-text-col {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  /* ── Eyebrow — muted, NOT green (Von Restorff) ── */
  .hasd-eyebrow {
    font-family: var(--cv-font-sans);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--cv-muted-fg);
    margin: 0;
  }

  /* ── Heading ── */
  .hasd-heading {
    font-family: var(--cv-font-head);
    font-size: clamp(1.75rem, 3vw, 2.625rem);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--cv-primary);
    margin: 0;
  }

  /* ── Green accent divider (subtle Von Restorff moment) ── */
  .hasd-divider {
    width: 3rem;
    height: 3px;
    background: var(--color-cta-primary);
    border: none;
    margin: 0;
    border-radius: 99px;
  }

  /* ── Richtext body ── */
  .hasd-body {
    font-family: var(--cv-font-sans);
    font-size: 1rem;
    line-height: 1.75;
    color: var(--cv-muted-fg);
    margin: 0;
  }
  .hasd-body p { margin: 0 0 0.75rem; }
  .hasd-body p:last-child { margin-bottom: 0; }
  .hasd-body strong { color: var(--cv-fg); font-weight: 600; }
  .hasd-body a { color: var(--cv-primary); text-decoration: underline; }

  /* ── CTA — outline, indigo (NOT green) ── */
  .hasd-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8125rem 1.5rem;
    background: transparent;
    color: var(--cv-primary);
    font-family: var(--cv-font-sans);
    font-size: 0.9375rem;
    font-weight: 600;
    letter-spacing: 0.01em;
    text-decoration: none;
    border: 2px solid var(--cv-primary);
    border-radius: var(--cv-radius);
    transition: background 0.18s ease, color 0.18s ease, transform 0.12s ease;
    align-self: flex-start;
  }
  .hasd-cta:hover {
    background: var(--cv-primary);
    color: #ffffff;
    transform: translateY(-1px);
  }
  .hasd-cta svg {
    flex-shrink: 0;
    transition: transform 0.15s ease;
  }
  .hasd-cta:hover svg {
    transform: translateX(3px);
  }

  /* ── Responsive ── */
  @media (max-width: 1023px) {
    .hasd-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .hasd-image-col,
    .hasd-text-col {
      order: unset;
    }
    /* On mobile, image always comes first */
    .hasd-image-col { order: 1; }
    .hasd-text-col  { order: 2; }
    .hasd-image-wrap {
      aspect-ratio: 3 / 2;
    }
    .hasd-heading {
      font-size: clamp(1.5rem, 5vw, 2rem);
    }
  }

  @media (max-width: 639px) {
    .hasd-section {
      padding: 3.5rem 1.25rem;
    }
    .hasd-image-wrap {
      aspect-ratio: 16 / 9;
    }
    .hasd-cta {
      align-self: stretch;
      justify-content: center;
    }
    .hasd-badge {
      bottom: 1rem;
      right: 1rem;
      left: auto;
    }
  }
  @media (max-width: 767px) {
    .hasd-badge { border: none !important; box-shadow: none !important; }
  }
</style>

<div class="hasd-section" id="hasd-{{ section.id }}">
  <div class="hasd-inner">

    {%- comment -%} ── IMAGE COLUMN ── {%- endcomment -%}
    <div class="hasd-image-col">
      <div class="hasd-image-wrap">
        {%- if img != blank -%}
          <img
            src="{{ img | image_url: width: 1000 }}"
            srcset="
              {{ img | image_url: width: 500  }} 500w,
              {{ img | image_url: width: 800  }} 800w,
              {{ img | image_url: width: 1000 }} 1000w,
              {{ img | image_url: width: 1400 }} 1400w
            "
            sizes="(max-width: 1023px) 100vw, 50vw"
            alt="{{ img.alt | escape | default: heading | escape }}"
            width="{{ img.width }}"
            height="{{ img.height }}"
            loading="lazy"
          >
        {%- else -%}
          {%- comment -%} Placeholder when no image set ── {%- endcomment -%}
          <div style="
            width: 100%; height: 100%;
            background: linear-gradient(135deg, #282d52 0%, #1c1f36 100%);
            display: flex; align-items: center; justify-content: center;
          ">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none"
              stroke="rgba(255,255,255,0.3)" stroke-width="1.25"
              stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="3" y="3" width="18" height="18" rx="2" ry="2"/>
              <circle cx="8.5" cy="8.5" r="1.5"/>
              <polyline points="21 15 16 10 5 21"/>
            </svg>
          </div>
        {%- endif -%}
      </div>

      {%- if img_badge != blank -%}
        <div class="hasd-badge" aria-hidden="true">
          <span class="hasd-badge__pin">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2.5"
              stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </span>
          <span class="hasd-badge__text">{{ img_badge | escape }}</span>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ── TEXT COLUMN ── {%- endcomment -%}
    <div class="hasd-text-col">

      {%- if eyebrow != blank -%}
        <p class="hasd-eyebrow">{{ eyebrow | escape }}</p>
      {%- endif -%}

      {%- if heading != blank -%}
        <h2 class="hasd-heading">{{ heading | escape }}</h2>
      {%- endif -%}

      <hr class="hasd-divider" aria-hidden="true">

      {%- if body_content != blank -%}
        <div class="hasd-body">{{ body_content }}</div>
      {%- endif -%}

      {%- if btn_text != blank -%}
        <a
          href="{{ btn_url | default: '#' }}"
          class="hasd-cta"
        >
          {{ btn_text | escape }}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="2.5"
            stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m9 18 6-6-6-6"/>
          </svg>
        </a>
      {%- endif -%}

    </div>

  </div>
</div>

{% schema %}
{
  "name": "About Supply District",
  "tag": "div",
  "class": "sd-about-section",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "left",  "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "image_badge",
      "label": "Image badge text",
      "info": "Short location or credential displayed as a floating tag on the image",
      "default": "Melbourne, AUS"
    },
    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "About Supply District"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Built by Collectors. Trusted by the Community."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text",
      "default": "<p>Supply District started as a passion project between two Melbourne-based collectors who were tired of paying inflated prices for sealed product — or worse, receiving damaged goods with no recourse.</p><p>We source <strong>directly from authorised Australian distributors</strong>, meaning every box, tin, and bundle you receive is 100% genuine, factory sealed, and handled with the care it deserves. No resealed packs. No grey-market imports. No shortcuts.</p><p>From our warehouse in Melbourne, we dispatch to collectors across Australia and New Zealand — fast, tracked, and packaged to survive the journey.</p>"
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button label",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "btn_url",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "About Supply District"
    }
  ]
}
{% endschema %}
