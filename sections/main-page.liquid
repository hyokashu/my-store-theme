<style>
@keyframes sd-fade-up {
  from { opacity: 0; transform: translateY(16px); }
  to   { opacity: 1; transform: translateY(0); }
}
.page { animation: sd-fade-up 0.5s ease both; animation-delay: 0.1s; }
</style>
<div class="page">
  <h1>{{ page.title }}</h1>
  {{ page.content }}
</div>
{% schema %}
{
  "name": "Page",
  "settings": []
}
{% endschema %}