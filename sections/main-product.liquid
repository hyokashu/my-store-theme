      <button type="button" class="cv-sticky-qty-btn" id="cv-sticky-qty-minus" aria-label="Decrease quantity">−</button>
      <span class="cv-sticky-qty-display" id="cv-sticky-qty-display">1</span>
      <button type="button" class="cv-sticky-qty-btn" id="cv-sticky-qty-plus" aria-label="Increase quantity">+</button>
    </div>
    <button
      class="cv-btn cv-btn--primary"
      style="flex:1;height:2.75rem;font-size:0.9375rem;background:var(--color-cta-primary);border-color:var(--color-cta-primary);color:var(--color-cta-primary-fg);"
      type="button"
      id="cv-sticky-atc"
      {% unless available %}disabled{% endunless %}
    >
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="width:1rem;height:1rem"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
      {% if available %}Add to Cart{% else %}Out of Stock{% endif %}
    </button>
  </div>
</div>

<script>
(function () {
  'use strict';

  /* ── 2. Random Live Viewers ── */
  var viewersEl = document.getElementById('cv-live-viewers');
  var viewersCount = document.getElementById('cv-viewers-count');
  if (viewersEl && viewersCount) {
    var viewers = Math.floor(Math.random() * 21); // 0 to 20
    if (viewers > 0) {
      viewersCount.textContent = viewers;
      viewersEl.style.display = 'inline-flex'; 
    } else {
      viewersEl.style.display = 'none';
    }
  }

/* ── 5. Dynamic Recent Sales (with Session Storage) ── */
  var recentDataEl = document.getElementById('cv-recent-products-data');
  if (recentDataEl) {
    try {
      var products = JSON.parse(recentDataEl.textContent);
      if (products.length > 0) {
        var listEl = document.getElementById('cv-recent-sales-list');
        var container = document.getElementById('cv-recent-sales-container');
        
        var storedData = sessionStorage.getItem('cv_recent_sales');
        var salesData = null;
        var now = Date.now();

        // 1. Check if we already have a generated list for this user session
        if (storedData) {
          try {
            salesData = JSON.parse(storedData);
          } catch(e) {}
        }

        // 2. If no list exists, generate one and save it to the browser
        if (!salesData || !salesData.sales || salesData.sales.length === 0) {
          products.sort(function() { return 0.5 - Math.random(); });
          var count = Math.min(4, products.length);
          var timeOffsetMins = Math.floor(Math.random() * 14) + 2; 
          
          var newSales = [];
          for (var i = 0; i < count; i++) {
            newSales.push({
              title: products[i].title,
              price: products[i].price,
              baseMinsAgo: timeOffsetMins
            });
            // Add a random chunk of time (15 to 50 mins) for the next item down
            timeOffsetMins += Math.floor(Math.random() * 36) + 15; 
          }

          salesData = {
            generatedAt: now,
            sales: newSales
          };
          sessionStorage.setItem('cv_recent_sales', JSON.stringify(salesData));
        }

        // 3. Render the list, calculating the true time elapsed since it was generated
        var elapsedMins = Math.floor((now - salesData.generatedAt) / 60000);
        
        for (var j = 0; j < salesData.sales.length; j++) {
          var sale = salesData.sales[j];
          var totalMins = sale.baseMinsAgo + elapsedMins;
          
          var timeString = '';
          if (totalMins < 60) {
            timeString = totalMins + ' minutes ago';
          } else {
            var hrs = Math.floor(totalMins / 60);
            timeString = hrs + (hrs === 1 ? ' hour ago' : ' hours ago');
          }

          var html = '<div class="cv-sale-item">' +
                       '<div class="cv-sale-item__info">' +
                         '<span class="cv-sale-item__name">' + sale.title + '</span>' +
                         '<span class="cv-sale-item__time">' + timeString + '</span>' +
                       '</div>' +
                       '<span class="cv-sale-item__price">' + sale.price + '</span>' +
                     '</div>';
          listEl.insertAdjacentHTML('beforeend', html);
        }
        
        container.style.display = 'block';
      }
    } catch(e) {}
  }

  /* ── Gallery ── */
  var gallery  = document.getElementById('cv-gallery');
  if (!gallery) return;

  var mainWrap  = document.getElementById('cv-gallery-main');
  var mainImg   = document.getElementById('cv-gallery-img');
  var counter   = document.getElementById('cv-gallery-counter');
  var prevBtn   = document.getElementById('cv-gallery-prev');
  var nextBtn   = document.getElementById('cv-gallery-next');
  var thumbs    = Array.prototype.slice.call(gallery.querySelectorAll('.cv-gallery__thumb'));
  var total     = thumbs.length;
  var current   = 0;
  var zoomed    = false;

  function setImage(index) {
    if (!thumbs[index]) return;
    current = index;
    var t = thumbs[index];
    if (zoomed) { mainWrap.classList.remove('is-zoomed'); zoomed = false; }
    thumbs.forEach(function(th) { th.classList.remove('is-active'); });
    t.classList.add('is-active');
    if (counter) counter.textContent = (index + 1) + ' / ' + total;
    mainImg.style.opacity = '0';
    mainImg.addEventListener('transitionend', function handler(e) {
      if (e.propertyName !== 'opacity') return;
      mainImg.removeEventListener('transitionend', handler);
      mainImg.src = t.dataset.src;
      mainImg.alt = t.dataset.alt || '';
      mainImg.onload = function () { mainImg.style.opacity = '1'; mainImg.onload = null; };
      if (mainImg.complete) mainImg.style.opacity = '1';
    });
  }

  thumbs.forEach(function(thumb) {
    thumb.addEventListener('click', function () {
      setImage(parseInt(this.dataset.index, 10));
    });
  });

  if (prevBtn) prevBtn.addEventListener('click', function (e) {
    e.stopPropagation();
    setImage(current === 0 ? total - 1 : current - 1);
  });
  if (nextBtn) nextBtn.addEventListener('click', function (e) {
    e.stopPropagation();
    setImage(current === total - 1 ? 0 : current + 1);
  });

  mainWrap.addEventListener('click', function () {
    zoomed = !zoomed;
    mainWrap.classList.toggle('is-zoomed', zoomed);
  });

  /* Touch swipe */
  var swipeX = 0;
  mainWrap.addEventListener('touchstart', function (e) { swipeX = e.changedTouches[0].screenX; }, { passive: true });
  mainWrap.addEventListener('touchend',   function (e) {
    var diff = swipeX - e.changedTouches[0].screenX;
    if (Math.abs(diff) > 40) setImage(diff > 0 ? (current === total - 1 ? 0 : current + 1) : (current === 0 ? total - 1 : current - 1));
  }, { passive: true });

  /* ── Quantity Stepper ── */
  var qtyInput = document.getElementById('cv-qty-input');
  var qtyMinus = document.getElementById('cv-qty-minus');
  var qtyPlus  = document.getElementById('cv-qty-plus');
  if (qtyInput && qtyMinus && qtyPlus) {
    qtyMinus.addEventListener('click', function () {
      var v = parseInt(qtyInput.value, 10) || 1;
      if (v > 1) qtyInput.value = v - 1;
    });
    qtyPlus.addEventListener('click', function () {
      qtyInput.value = (parseInt(qtyInput.value, 10) || 1) + 1;
    });
    qtyInput.addEventListener('change', function () {
      var v = parseInt(qtyInput.value, 10);
      if (isNaN(v) || v < 1) qtyInput.value = 1;
      if (stickyQtyDisplay) stickyQtyDisplay.textContent = qtyInput.value;
    });
  }

  /* ── Sticky Qty Sync ── */
  var stickyQtyDisplay = document.getElementById('cv-sticky-qty-display');
  var stickyQtyMinus   = document.getElementById('cv-sticky-qty-minus');
  var stickyQtyPlus    = document.getElementById('cv-sticky-qty-plus');
  if (stickyQtyMinus && stickyQtyPlus && stickyQtyDisplay) {
    stickyQtyMinus.addEventListener('click', function () {
      var v = parseInt(stickyQtyDisplay.textContent, 10) || 1;
      if (v > 1) {
        stickyQtyDisplay.textContent = v - 1;
        if (qtyInput) qtyInput.value = v - 1;
      }
    });
    stickyQtyPlus.addEventListener('click', function () {
      var v = parseInt(stickyQtyDisplay.textContent, 10) || 1;
      stickyQtyDisplay.textContent = v + 1;
      if (qtyInput) qtyInput.value = v + 1;
    });
  }

  /* ── Wishlist Toggle ── */
  var wishBtn = document.getElementById('cv-wishlist-btn');
  if (wishBtn) {
    wishBtn.addEventListener('click', function () {
      var pressed = this.getAttribute('aria-pressed') === 'true';
      this.setAttribute('aria-pressed', String(!pressed));
      this.classList.toggle('is-wishlisted', !pressed);
      this.setAttribute('aria-label', !pressed ? 'Remove from wishlist' : 'Add to wishlist');
    });
  }

  /* ── Share Button ── */
  var shareBtn = document.getElementById('cv-share-btn');
  if (shareBtn) {
    shareBtn.addEventListener('click', function () {
      if (navigator.share) {
        navigator.share({ title: document.title, url: window.location.href });
      } else if (navigator.clipboard) {
        navigator.clipboard.writeText(window.location.href).then(function () {
          var orig = shareBtn.getAttribute('aria-label');
          shareBtn.setAttribute('aria-label', 'Link copied!');
          setTimeout(function () { shareBtn.setAttribute('aria-label', orig); }, 2000);
        });
      }
    });
  }

  /* ── Tabs ── */
  var triggers = Array.prototype.slice.call(document.querySelectorAll('.cv-tabs__trigger'));
  var panels   = Array.prototype.slice.call(document.querySelectorAll('.cv-tabs__panel'));
  triggers.forEach(function (trig) {
    trig.addEventListener('click', function () {
      triggers.forEach(function (t) { t.classList.remove('is-active'); t.setAttribute('aria-selected', 'false'); });
      panels.forEach(function (p)   { p.classList.remove('is-active'); });
      this.classList.add('is-active');
      this.setAttribute('aria-selected', 'true');
      var panel = document.getElementById('cv-tab-' + this.dataset.tab);
      if (panel) panel.classList.add('is-active');
    });
  });

/* ── Ajax Add to Cart (Animated) ── */
  var form      = document.getElementById('cv-product-form');
  var atcBtn    = document.getElementById('cv-add-to-cart');
  var stickyAtc = document.getElementById('cv-sticky-atc');

  function submitCart(event, btnElement) {
    if (!form || !btnElement) return;
    
    // Save original button HTML to restore later
    var originalHtml = btnElement.innerHTML;
    
    // Disable button and trigger pulsating dot loading state
    btnElement.disabled = true;
    btnElement.innerHTML = '<span style="display:flex;align-items:center;justify-content:center;">Adding <span class="cv-pulsating-dot"></span></span>';

    var formData = new FormData(form);
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'X-Requested-With': 'XMLHttpRequest', 'Accept': 'application/json' },
      body: formData
    })
    .then(function (r) { return r.json(); })
    .then(function () {
      // Success State: Button pop, green color, checkmark icon
      btnElement.classList.add('is-success');
      btnElement.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="width:1.25rem;height:1.25rem;margin-right:0.5rem;"><polyline points="20 6 9 17 4 12"/></svg> Added to Cart';
      
      // Update cart count badge if it exists on your theme
      fetch('/cart.js').then(function (r) { return r.json(); }).then(function (cart) {
        var badge = document.querySelector('[data-cart-count]');
        if (badge) badge.textContent = cart.item_count;
      });

      // Restore button to original state after 2.5 seconds
      setTimeout(function () {
        btnElement.disabled = false;
        btnElement.classList.remove('is-success');
        btnElement.style.transform = 'scale(1)';
        btnElement.innerHTML = originalHtml;
      }, 2500);
    })
    .catch(function () {
      // Error State
      btnElement.innerHTML = 'Error \u2013 Try Again';
      btnElement.disabled = false;
      setTimeout(function () { btnElement.innerHTML = originalHtml; }, 3000);
    });
  }

  // Bind the updated function to both buttons
  if (form && atcBtn) {
    form.addEventListener('submit', function (e) { 
      e.preventDefault(); 
      submitCart(e, atcBtn); 
    });
  }
  if (stickyAtc) {
    stickyAtc.addEventListener('click', function(e) {
      e.preventDefault();
      submitCart(e, stickyAtc);
    });
  }

  /* ── Buy Now ── */
  var buyNow = document.getElementById('cv-buy-now');
  if (buyNow) {
    buyNow.addEventListener('click', function (e) {
      e.preventDefault();
      var vid = document.getElementById('cv-variant-id').value;
      var qty = qtyInput ? (parseInt(qtyInput.value, 10) || 1) : 1;
      window.location.href = '/cart/' + vid + ':' + qty;
    });
  }

  /* ── Dispatch Countdown Timer ── */
  (function () {
    var timerEl = document.getElementById('cv-dispatch-timer');
    var textEl  = document.getElementById('cv-dispatch-text');
    if (!timerEl || !textEl) return;

    var CUTOFF_HOUR   = 14;   /* 2:00 PM */
    var CUTOFF_MINUTE = 0;

    function update() {
      var now     = new Date();
      var cutoff  = new Date(now);
      cutoff.setHours(CUTOFF_HOUR, CUTOFF_MINUTE, 0, 0);

      /* If cutoff has already passed today, point to tomorrow */
      if (now >= cutoff) {
        cutoff.setDate(cutoff.getDate() + 1);
      }

      var diffMs  = cutoff - now;
      var diffSec = Math.floor(diffMs / 1000);
      var hrs     = Math.floor(diffSec / 3600);
      var mins    = Math.floor((diffSec % 3600) / 60);

      if (hrs <= 0 && mins <= 0) {
        timerEl.classList.add('cv-dispatch-timer--expired');
        textEl.innerHTML = 'Order now — dispatches <strong>next business day</strong>';
      } else {
        timerEl.classList.remove('cv-dispatch-timer--expired');
        var parts = [];
        if (hrs > 0)  parts.push('<strong>' + hrs  + ' hr'  + (hrs  !== 1 ? 's' : '') + '</strong>');
        if (mins > 0) parts.push('<strong>' + mins + ' min' + (mins !== 1 ? 's' : '') + '</strong>');
        textEl.innerHTML = 'Order within ' + parts.join(' ') + ' for same-day dispatch';
      }
    }

    update();
    setInterval(update, 30000); /* refresh every 30 s */
  }());

  /* ── Hide sticky cart when hero is visible ── */
  var stickyCart = document.getElementById('cv-sticky-cart');
  var heroEl     = document.querySelector('.cv-hero');
  if (stickyCart && heroEl && 'IntersectionObserver' in window) {
    var obs = new IntersectionObserver(function (entries) {
      stickyCart.style.transform = entries[0].isIntersecting ? 'translateY(100%)' : 'translateY(0)';
    }, { threshold: 0.05 });
    obs.observe(heroEl);
  }

}());
</script>

