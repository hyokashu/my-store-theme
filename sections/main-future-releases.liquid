{%- comment -%} ── Future Releases ── {%- endcomment -%}

<style>
  html { scroll-behavior: smooth; }

  .sfr-wrap {
    max-width: 90rem;
    margin: 0 auto;
    padding: 3.5rem 2rem 5rem;
    background: var(--cv-bg, #f4f0e8);
  }

  .sfr-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .sfr-header__title {
    font-family: var(--cv-font-head, 'Nunito', system-ui, sans-serif);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 700;
    color: var(--cv-primary, #2d5016);
    line-height: 1.15;
    margin: 0 0 0.75rem;
  }

  .sfr-header__sub {
    font-family: var(--cv-font-sans, 'Inter', system-ui, sans-serif);
    font-size: 1.0625rem;
    color: var(--cv-muted-fg, #6b7a5a);
    max-width: 48ch;
    margin: 0 auto;
    line-height: 1.6;
  }

  .sfr-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 900px) {
    .sfr-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 560px) {
    .sfr-grid { grid-template-columns: 1fr; }
    .sfr-wrap { padding: 2.5rem 1rem 3.5rem; }
  }

  .future-release-card {
    background: var(--cv-card, #ffffff);
    border: 1px solid var(--cv-border, #d4cdb8);
    border-radius: var(--cv-radius, 0.5rem);
    box-shadow: var(--cv-shadow, 0 1px 3px rgba(0,0,0,0.07), 0 1px 2px rgba(0,0,0,0.05));
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.22s ease, transform 0.22s ease;
  }

  .future-release-card:hover {
    box-shadow: 0 8px 28px rgba(10,26,5,0.14);
    transform: translateY(-2px);
  }

  .sfr-card__img-wrap {
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--cv-secondary, #e2ddd0);
  }

  .sfr-card__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .sfr-card__img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--cv-muted-fg, #6b7a5a);
  }

  .sfr-card__body {
    padding: 1.25rem 1.5rem 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .sfr-card__name {
    font-family: var(--cv-font-head, 'Nunito', system-ui, sans-serif);
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--cv-primary, #2d5016);
    margin: 0;
    line-height: 1.3;
  }

  .sfr-card__eta-label {
    font-family: var(--cv-font-sans, 'Inter', system-ui, sans-serif);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--cv-muted-fg, #6b7a5a);
    margin: 0.25rem 0 0;
  }

  .sfr-card__eta {
    font-family: var(--cv-font-sans, 'Inter', system-ui, sans-serif);
    font-size: 0.9375rem;
    color: var(--cv-fg, #1a2510);
    margin: 0;
  }

  .sfr-card__cta {
    margin-top: auto;
    padding-top: 1rem;
  }

  .sfr-card__btn {
    display: inline-block;
    width: 100%;
    text-align: center;
    padding: 0.625rem 1.25rem;
    background: var(--color-cta-primary, #3d7a1f);
    color: var(--color-cta-primary-fg, #ffffff);
    font-family: var(--cv-font-sans, 'Inter', system-ui, sans-serif);
    font-size: 0.9375rem;
    font-weight: 600;
    border-radius: var(--cv-radius, 0.5rem);
    text-decoration: none;
    transition: background 0.18s ease;
    box-sizing: border-box;
  }

  .sfr-card__btn:hover {
    background: var(--color-cta-primary-hover, #2d5a15);
  }
</style>

<div class="sfr-wrap">

  {%- comment -%} ── Section Header ── {%- endcomment -%}
  <div class="sfr-header">
    {%- if section.settings.title != blank -%}
      <h1 class="sfr-header__title">{{ section.settings.title | escape }}</h1>
    {%- endif -%}
    {%- if section.settings.subtext != blank -%}
      <p class="sfr-header__sub">{{ section.settings.subtext | escape }}</p>
    {%- endif -%}
  </div>

  {%- comment -%} ── Release Cards Grid ── {%- endcomment -%}
  {%- if section.blocks.size > 0 -%}
    <div class="sfr-grid">
      {%- for block in section.blocks -%}
        <div
          {%- if block.settings.anchor_id != blank -%}
            id="{{ block.settings.anchor_id | handleize }}"
          {%- endif -%}
          class="future-release-card"
          {{ block.shopify_attributes }}
        >
          {%- comment -%} Image {%- endcomment -%}
          <div class="sfr-card__img-wrap">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 600 }}"
                alt="{{ block.settings.set_name | default: block.settings.image.alt | escape }}"
                width="600"
                height="450"
                loading="lazy"
              >
            {%- else -%}
              <div class="sfr-card__img-placeholder">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
              </div>
            {%- endif -%}
          </div>

          {%- comment -%} Body {%- endcomment -%}
          <div class="sfr-card__body">
            {%- if block.settings.set_name != blank -%}
              <h2 class="sfr-card__name">{{ block.settings.set_name | escape }}</h2>
            {%- endif -%}

            {%- if block.settings.estimated_arrival != blank -%}
              <p class="sfr-card__eta-label">Estimated Arrival</p>
              <p class="sfr-card__eta">{{ block.settings.estimated_arrival | escape }}</p>
            {%- endif -%}

            {%- if block.settings.notify_me_url != blank -%}
              <div class="sfr-card__cta">
                <a href="{{ block.settings.notify_me_url | escape }}" class="sfr-card__btn">Notify Me</a>
              </div>
            {%- endif -%}
          </div>

        </div>
      {%- endfor -%}
    </div>
  {%- endif -%}

</div>

{% schema %}
{
  "name": "Future Releases",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Future Releases"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Stay ahead of the pack. Here's what's dropping soon."
    }
  ],
  "blocks": [
    {
      "type": "release",
      "name": "TCG Set",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Set Image"
        },
        {
          "type": "text",
          "id": "set_name",
          "label": "Set Name",
          "default": "Set Name"
        },
        {
          "type": "text",
          "id": "estimated_arrival",
          "label": "Estimated Arrival",
          "default": "Q1 2026"
        },
        {
          "type": "text",
          "id": "anchor_id",
          "label": "Anchor ID",
          "info": "Used for direct nav links (e.g. 'pokemon' → /pages/future-releases#pokemon). Lowercase, no spaces.",
          "default": "set-name"
        },
        {
          "type": "url",
          "id": "notify_me_url",
          "label": "Notify Me URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Future Releases",
      "blocks": [
        { "type": "release" },
        { "type": "release" },
        { "type": "release" }
      ]
    }
  ],
  "max_blocks": 20
}
{% endschema %}
