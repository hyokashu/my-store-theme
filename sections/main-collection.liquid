{% comment %}
  Sprout — sections/main-collection.liquid  v2
  ──────────────────────────────────────────────────────
  Layout: full-width banner → 2-column catalog body.
  Desktop (≥1024px): 280px sticky filter sidebar (left) + product grid (right).
  Mobile (<1024px):  1-column; sidebar hidden; "Filters & Sort" button in topbar
                     opens a slide-in panel from the left edge.
  All design tokens, shared CSS and JS live in sd-collection.{css,js}.
{% endcomment %}

{{ 'sd-collection.css' | asset_url | stylesheet_tag }}
<script src="{{ 'sd-collection.js' | asset_url }}" defer></script>

{%- liquid
  assign sort_by           = collection.sort_by | default: collection.default_sort_by
  assign products_per_page = section.settings.products_per_page | default: 24
  assign show_filters      = section.settings.show_filters
  assign active_filters    = collection.active_filters
  assign has_active        = false
  if active_filters.size > 0
    assign has_active = true
  endif
-%}

{%- comment -%} ════════════════════════════════════════
    BANNER — breadcrumbs · title · description · count
════════════════════════════════════════ {%- endcomment -%}

<style>
  /* Scoped Banner Styles utilizing our global tokens */
  .sdcb-banner {
    background: linear-gradient(110deg, #2C4731 60%, #3a5c1e 100%);
    padding: 2rem 1rem 1.75rem;
    border-bottom: none;
  }
  .sdcb-banner__inner {
    max-width: 90rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Hero image variant */
  .sdcb-banner--has-image {
    background-size: cover;
    background-position: center;
    min-height: 240px;
    position: relative;
    border-bottom: none;
    padding: 4rem 1rem 3rem;
  }
  .sdcb-banner--has-image::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(10,12,30,0.72) 0%, rgba(10,12,30,0.32) 60%, rgba(10,12,30,0.10) 100%);
    pointer-events: none;
  }
  .sdcb-banner--has-image .sdcb-banner__inner { position: relative; z-index: 1; }
  .sdcb-banner--has-image .sdcb-banner__title { color: #fff; text-shadow: 0px 2px 8px rgba(0,0,0,0.8), 0px 0px 4px rgba(0,0,0,0.6); }
  .sdcb-banner--has-image .sdcb-banner__desc { color: rgba(255,255,255,0.85); }
  .sdcb-banner--has-image .sdcb-banner__meta { color: rgba(255,255,255,0.65); }
  .sdcb-banner--has-image .cv-breadcrumb,
  .sdcb-banner--has-image .cv-breadcrumb a,
  .sdcb-banner--has-image .cv-breadcrumb__sep { color: rgba(255,255,255,0.6); }
  .sdcb-banner--has-image .cv-breadcrumb__current { color: rgba(255,255,255,0.9); }
  .sdcb-banner--has-image .cv-breadcrumb a:hover { color: #fff; }

  /* Overriding the broken breadcrumbs seen in the screenshot */
  .sdcb-banner .cv-breadcrumb {
    list-style: none; padding: 0; margin: 0;
    display: flex; gap: 0.375rem;
    font-family: var(--cv-font-sans, 'Inter', sans-serif);
    font-size: 0.875rem; color: rgba(255,255,255,0.65);
    flex-wrap: wrap; align-items: center;
  }
  .sdcb-banner .cv-breadcrumb a { color: #C59B43; text-decoration: none; transition: color 0.15s; }
  .sdcb-banner .cv-breadcrumb a:hover { color: #ffffff; }
  .sdcb-banner .cv-breadcrumb__sep { color: rgba(255,255,255,0.3); }
  .sdcb-banner .cv-breadcrumb__current { color: #ffffff; font-weight: 600; }

  .sdcb-banner__title {
    font-family: var(--cv-font-head, 'Nunito', sans-serif);
    font-size: clamp(1.75rem, 4vw, 2.75rem);
    font-weight: 800;
    color: #ffffff;
    letter-spacing: -0.02em;
    margin: 0;
  }

  .sdcb-banner__desc {
    font-family: var(--cv-font-sans);
    font-size: 1rem;
    color: rgba(255,255,255,0.75);
    max-width: 48rem;
    line-height: 1.6;
    margin: 0;
  }

  .sdcb-banner__meta {
    font-family: var(--cv-font-sans);
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(255,255,255,1);
    letter-spacing: 0.02em;
    margin-top: 0.25rem;
  }
</style>

<div class="sdcb-banner{% if collection.featured_image %} sdcb-banner--has-image{% endif %}"
  {% if collection.featured_image %}style="background-image: url('{{ collection.featured_image | image_url: width: 1800 }}')"{% endif %}>
  <div class="sdcb-banner__inner">

    {%- comment -%} 
      Replaced the external 'breadcrumbs' snippet with a hardcoded clean version 
      to immediately fix the numbered list formatting bug 
    {%- endcomment -%}
    <nav aria-label="Breadcrumb">
      <ul class="cv-breadcrumb">
        <li><a href="{{ routes.root_url }}">Home</a></li>
        <li class="cv-breadcrumb__sep" aria-hidden="true">/</li>
        <li><span class="cv-breadcrumb__current" aria-current="page">{{ collection.title | escape }}</span></li>
      </ul>
    </nav>

    <h1 class="sdcb-banner__title">{{ collection.title | escape }}</h1>

    {%- if collection.description != blank -%}
      <div class="sdcb-banner__desc">{{ collection.description }}</div>
    {%- endif -%}

    <div class="sdcb-banner__meta">
      {%- assign pc = collection.products_count -%}
      <span class="sdcb-banner__count">
        {%- if pc == 0 -%}
          No products
        {%- elsif pc == 1 -%}
          1 product
        {%- else -%}
          {{ pc }} products
        {%- endif -%}
      </span>
    </div>

  </div>
</div>

{%- comment -%} ════════════════════════════════════════
    CATALOG BODY — sidebar + main
════════════════════════════════════════ {%- endcomment -%}

{%- paginate collection.products by products_per_page -%}

<div class="sd-catalog" id="sd-catalog">
  <div class="sd-catalog__wrap{% if show_filters %} sd-catalog__wrap--sidebar{% endif %}">

    {%- comment -%} ── LEFT: Filter sidebar (desktop sticky · mobile hidden · mobile panel injected) ── {%- endcomment -%}
    {%- if show_filters -%}
      {%- render 'facets', results: collection -%}
    {%- endif -%}

    {%- comment -%} ── RIGHT: Main content area ── {%- endcomment -%}
    <main class="sd-catalog__main" id="sd-catalog-main" aria-label="Products">

      {%- comment -%} ─── Topbar: mobile filter trigger · count · desktop sort ─── {%- endcomment -%}
      <div class="sd-catalog__topbar">

        {%- if show_filters -%}
          <button
            class="sdcf-mobile-trigger"
            type="button"
            id="sdcf-mobile-trigger"
            aria-controls="sdcf-mobile-panel"
            aria-expanded="false"
          >
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
              stroke="currentColor" stroke-width="2.2" stroke-linecap="round"
              stroke-linejoin="round" aria-hidden="true">
              <line x1="4" y1="6"  x2="20" y2="6"/>
              <line x1="4" y1="12" x2="16" y2="12"/>
              <line x1="4" y1="18" x2="12" y2="18"/>
            </svg>
            Filters &amp; Sort
            {%- if has_active -%}
              <span
                class="sdcf-mobile-trigger__badge"
                aria-label="{{ active_filters.size }} active filter{% if active_filters.size != 1 %}s{% endif %}"
              >{{ active_filters.size }}</span>
            {%- endif -%}
          </button>
        {%- endif -%}

        <p class="sd-catalog__count">
          {%- if collection.products_count == 0 -%}
            No products
          {%- elsif collection.products_count == 1 -%}
            1 product
          {%- else -%}
            {{ collection.products_count }} products
          {%- endif -%}
        </p>

        {%- if collection.sort_options.size > 0 -%}
          <div class="sd-catalog__sort-wrap">
            <label class="sd-catalog__sort-label" for="sd-sort-select">Sort:</label>
            <select
              class="sdcf-sort-select"
              id="sd-sort-select"
              aria-label="Sort products"
            >
              {%- for option in collection.sort_options -%}
                <option
                  value="{{ option.value | escape }}"
                  {%- if option.value == sort_by %} selected{%- endif -%}
                >{{ option.name | escape }}</option>
              {%- endfor -%}
            </select>
          </div>
        {%- endif -%}

      </div>{%- comment -%} /.sd-catalog__topbar {%- endcomment -%}

      {%- comment -%} ── Mobile inline filter accordion ── {%- endcomment -%}
      {%- if show_filters -%}
        <div class="sdcl-mobile-panel" id="sdcf-mobile-panel" aria-hidden="true">
          <div class="sdcl-mobile-panel__body">

            {%- if collection.sort_options.size > 0 -%}
              <div class="sdcl-mobile-sort">
                <p class="sdcl-mobile-sort__title">Sort by</p>
                <div class="sdcl-mobile-sort__options">
                  {%- for option in collection.sort_options -%}
                    <a
                      href="{{ collection.url | split: '?' | first }}?sort_by={{ option.value | url_encode }}"
                      class="sdcf-sort-option{% if option.value == sort_by %} is-active{% endif %}"
                      data-sort="{{ option.value | escape }}"
                    >
                      <span class="sdcf-sort-radio" aria-hidden="true"></span>
                      {{ option.name | escape }}
                    </a>
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}

            {%- if collection.filters.size > 0 -%}
              {%- for filter in collection.filters -%}
                {%- liquid
                  assign filter_has_active = false
                  for value in filter.active_values
                    assign filter_has_active = true
                    break
                  endfor
                -%}
                <div class="sdcl-mobile-group{% if filter_has_active %} is-open{% endif %}">
                  <button
                    class="sdcl-mobile-group__header"
                    type="button"
                    aria-expanded="{{ filter_has_active }}"
                  >
                    {{ filter.label | escape }}
                    {%- if filter_has_active and filter.type != 'price_range' -%}
                      <span class="sdcl-accordion__badge" aria-hidden="true">{{ filter.active_values.size }}</span>
                    {%- endif -%}
                    <svg class="sdcl-accordion__chevron" width="13" height="13"
                      viewBox="0 0 24 24" fill="none" stroke="currentColor"
                      stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                      aria-hidden="true">
                      <polyline points="6 9 12 15 18 9"/>
                    </svg>
                  </button>
                  {%- if filter.type == 'list' or filter.type == 'boolean' -%}
                    <ul class="sdcl-accordion__list sdcl-mobile-group__list" role="list">
                      {%- for value in filter.values -%}
                        <li role="listitem">
                          <a
                            href="{% if value.active %}{{ value.url_to_remove }}{% else %}{{ value.url_to_add }}{% endif %}"
                            class="sdcf-option__label{% if value.active %} is-active{% endif %}{% if value.count == 0 %} sdcf-option__label--disabled{% endif %}"
                            aria-pressed="{{ value.active }}"
                          >
                            <span class="sdcf-option__check" aria-hidden="true"></span>
                            <span class="sdcf-option__text">{{ value.label | escape }}</span>
                            <span class="sdcf-option__count">{{ value.count }}</span>
                          </a>
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}
                </div>
              {%- endfor -%}
            {%- endif -%}

            {%- if has_active -%}
              <div class="sdcl-mobile-panel__clear">
                <a href="{{ collection.url | split: '?' | first }}" class="sdcl-mobile-panel__clear-link">Clear all filters</a>
              </div>
            {%- endif -%}

          </div>
        </div>
      {%- endif -%}

      {%- comment -%} ─── Active filter pills ─── {%- endcomment -%}
      {%- if has_active -%}
        <div class="sdcf-active-pills" role="group" aria-label="Active filters">
          {%- for filter in active_filters -%}
            <a
              href="{{ filter.url_to_remove }}"
              class="sdcf-pill"
              aria-label="Remove filter: {{ filter.label | escape }}"
            >
              {{ filter.label | escape }}
              <span class="sdcf-pill__remove" aria-hidden="true">
                <svg width="9" height="9" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="3.5"
                  stroke-linecap="round" stroke-linejoin="round">
                  <line x1="18" y1="6"  x2="6"  y2="18"/>
                  <line x1="6"  y1="6"  x2="18" y2="18"/>
                </svg>
              </span>
            </a>
          {%- endfor -%}
          <a
            href="{{ collection.url | split: '?' | first }}"
            class="sdcf-clear-all"
          >Clear all</a>
        </div>
      {%- endif -%}

      {%- comment -%} ─── Product grid ─── {%- endcomment -%}
      {%- if collection.products.size > 0 -%}

        <div class="sdcpg__grid">
          {%- for product in collection.products -%}
            {%- render 'sd-product-card', product: product -%}
          {%- endfor -%}
        </div>

        {%- comment -%} ── Pagination ── {%- endcomment -%}
        {%- if paginate.pages > 1 -%}
          <nav class="sdcpg__pagination" aria-label="Collection pages">

            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}" class="sdcpg__page-link" aria-label="Previous page">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2.5"
                  stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="m15 18-6-6 6-6"/>
                </svg>
              </a>
            {%- endif -%}

            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}" class="sdcpg__page-link">{{ part.title }}</a>
              {%- elsif part.title == paginate.current_page -%}
                <span class="sdcpg__page-current" aria-current="page">{{ part.title }}</span>
              {%- else -%}
                <span class="sdcpg__page-dots">{{ part.title }}</span>
              {%- endif -%}
            {%- endfor -%}

            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}" class="sdcpg__page-link" aria-label="Next page">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2.5"
                  stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="m9 18 6-6-6-6"/>
                </svg>
              </a>
            {%- endif -%}

          </nav>
        {%- endif -%}

      {%- else -%}

        {%- comment -%} ── Empty state ── {%- endcomment -%}
        <div class="sdcpg__empty">
          <svg class="sdcpg__empty-icon" width="60" height="60" viewBox="0 0 24 24" fill="none"
            stroke="currentColor" stroke-width="1.25"
            stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/>
            <path d="m21 21-4.35-4.35"/>
            <line x1="8" y1="11" x2="14" y2="11"/>
          </svg>
          <h2 class="sdcpg__empty-title">No products found</h2>
          <p class="sdcpg__empty-text">
            Try adjusting or clearing your filters to find what you're looking for.
          </p>
          <a
            href="{{ collection.url | split: '?' | first }}"
            class="sdcpg__empty-cta"
          >Clear all filters</a>
        </div>

      {%- endif -%}

    </main>{%- comment -%} /.sd-catalog__main {%- endcomment -%}

  </div>{%- comment -%} /.sd-catalog__wrap {%- endcomment -%}
</div>{%- comment -%} /.sd-catalog {%- endcomment -%}

{%- endpaginate -%}

{% schema %}
{
  "name": "Collection",
  "tag": "div",
  "class": "sd-collection-page",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    },
    {
      "type": "checkbox",
      "id": "show_filters",
      "label": "Show filter sidebar",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Collection Page"
    }
  ]
}
{% endschema %}
