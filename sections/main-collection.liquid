{% comment %}
  Supply District — sections/main-collection.liquid
  Full collection page: Banner · Breadcrumbs · Facet Filters · Product Grid.
  All design tokens, CSS, and JS are loaded from sd-collection.{css,js}.
  This single section is the entry point for the collection Liquid template.
  (If migrating to JSON templates, split into separate section files instead.)
{% endcomment %}

{{ 'sd-collection.css' | asset_url | stylesheet_tag }}
<script src="{{ 'sd-collection.js' | asset_url }}" defer></script>

{%- liquid
  assign sort_by = collection.sort_by | default: collection.default_sort_by
  assign products_per_page = section.settings.products_per_page | default: 24
-%}

{%- comment -%} ════════════════════════════════
    BANNER — breadcrumbs + title + description
════════════════════════════════ {%- endcomment -%}

<style>
  /* Scoped Banner Styles utilizing our global tokens */
  .sdcb-banner {
    background: var(--cv-bg, #f7f6f3);
    padding: 3rem 1rem 2.5rem;
    border-bottom: 1px solid var(--cv-border, #dedad5);
  }
  .sdcb-banner__inner {
    max-width: 80rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  
  /* Overriding the broken breadcrumbs seen in the screenshot */
  .sdcb-banner .cv-breadcrumb {
    list-style: none; padding: 0; margin: 0;
    display: flex; gap: 0.375rem;
    font-family: var(--cv-font-sans, 'Inter', sans-serif); 
    font-size: 0.875rem; color: var(--cv-muted-fg, #76798c);
    flex-wrap: wrap; align-items: center;
  }
  .sdcb-banner .cv-breadcrumb a { color: var(--cv-muted-fg); text-decoration: none; transition: color 0.15s; }
  .sdcb-banner .cv-breadcrumb a:hover { color: var(--cv-fg, #1c1f36); }
  .sdcb-banner .cv-breadcrumb__sep { color: var(--cv-border); }
  .sdcb-banner .cv-breadcrumb__current { color: var(--cv-fg); font-weight: 500; }

  .sdcb-banner__title {
    font-family: var(--cv-font-head, 'Space Grotesk', sans-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: var(--cv-primary, #282d52);
    letter-spacing: -0.02em;
    margin: 0;
  }
  
  .sdcb-banner__desc {
    font-family: var(--cv-font-sans);
    font-size: 1rem;
    color: var(--cv-muted-fg);
    max-width: 48rem;
    line-height: 1.6;
    margin: 0;
  }
  
  .sdcb-banner__meta {
    font-family: var(--cv-font-sans);
    font-size: 0.75rem;
    font-weight: 700;
    color: var(--cv-muted-fg);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 0.5rem;
  }
</style>

<div class="sdcb-banner">
  <div class="sdcb-banner__inner">

    {%- comment -%} 
      Replaced the external 'breadcrumbs' snippet with a hardcoded clean version 
      to immediately fix the numbered list formatting bug 
    {%- endcomment -%}
    <nav aria-label="Breadcrumb">
      <ul class="cv-breadcrumb">
        <li><a href="{{ routes.root_url }}">Home</a></li>
        <li class="cv-breadcrumb__sep" aria-hidden="true">/</li>
        <li><span class="cv-breadcrumb__current" aria-current="page">{{ collection.title | escape }}</span></li>
      </ul>
    </nav>

    <h1 class="sdcb-banner__title">{{ collection.title | escape }}</h1>

    {%- if collection.description != blank -%}
      <div class="sdcb-banner__desc">{{ collection.description }}</div>
    {%- endif -%}

    <div class="sdcb-banner__meta">
      {%- assign pc = collection.products_count -%}
      <span class="sdcb-banner__count">
        {%- if pc == 0 -%}
          No products
        {%- elsif pc == 1 -%}
          1 product
        {%- else -%}
          {{ pc }} products
        {%- endif -%}
      </span>
    </div>

  </div>
</div>

{%- comment -%} ════════════════════════════════
    FACETS — filter bar + mobile drawer
════════════════════════════════ {%- endcomment -%}

{%- if section.settings.show_filters -%}
  {%- render 'facets', results: collection, results_count: collection.products_count -%}
{%- endif -%}

{%- comment -%} ════════════════════════════════
    PRODUCT GRID
════════════════════════════════ {%- endcomment -%}

{%- paginate collection.products by products_per_page -%}

<section class="sdcpg" aria-label="Products">
  <div class="sdcpg__inner">

    {%- comment -%} ── Top bar: count ── {%- endcomment -%}
    <div class="sdcpg__topbar">
      <p class="sdcpg__count">
        {%- if collection.products_count == 0 -%}
          No products
        {%- elsif collection.products_count == 1 -%}
          1 product
        {%- else -%}
          {{ collection.products_count }} products
        {%- endif -%}
      </p>
    </div>

    {%- if collection.products.size > 0 -%}

      <div class="sdcpg__grid">
        {%- for product in collection.products -%}
          {%- render 'sd-product-card', product: product -%}
        {%- endfor -%}
      </div>

      {%- comment -%} ── Pagination ── {%- endcomment -%}
      {%- if paginate.pages > 1 -%}
        <nav class="sdcpg__pagination" aria-label="Collection pages">

          {%- if paginate.previous -%}
            <a href="{{ paginate.previous.url }}" class="sdcpg__page-link" aria-label="Previous page">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2.5"
                stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="m15 18-6-6 6-6"/>
              </svg>
            </a>
          {%- endif -%}

          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}" class="sdcpg__page-link">{{ part.title }}</a>
            {%- elsif part.title == paginate.current_page -%}
              <span class="sdcpg__page-current" aria-current="page">{{ part.title }}</span>
            {%- else -%}
              <span class="sdcpg__page-dots">{{ part.title }}</span>
            {%- endif -%}
          {%- endfor -%}

          {%- if paginate.next -%}
            <a href="{{ paginate.next.url }}" class="sdcpg__page-link" aria-label="Next page">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2.5"
                stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="m9 18 6-6-6-6"/>
              </svg>
            </a>
          {%- endif -%}

        </nav>
      {%- endif -%}

    {%- else -%}

      {%- comment -%} ── Empty state ── {%- endcomment -%}
      <div class="sdcpg__empty">
        <svg class="sdcpg__empty-icon" width="56" height="56" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="1.5"
          stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          <line x1="8" y1="11" x2="14" y2="11"/>
        </svg>
        <h2 class="sdcpg__empty-title">No products found</h2>
        <p class="sdcpg__empty-text">
          Try adjusting or clearing your filters, or browse the full collection.
        </p>
        <a href="{{ collection.url | split: '?' | first }}"
          style="
            display:inline-flex;align-items:center;margin-top:1.25rem;
            padding:0.65rem 1.5rem;border-radius:999px;
            background:var(--cv-primary);color:var(--cv-primary-fg);
            font-weight:600;font-size:0.875rem;text-decoration:none;">
          Clear all filters
        </a>
      </div>

    {%- endif -%}

  </div>
</section>

{%- endpaginate -%}

{% schema %}
{
  "name": "Collection",
  "tag": "div",
  "class": "sd-collection-page",
  "settings": [
    {
      "type": "range",
      "id": "products_per_page",
      "label": "Products per page",
      "min": 8,
      "max": 48,
      "step": 4,
      "default": 24
    },
    {
      "type": "checkbox",
      "id": "show_filters",
      "label": "Show filter bar",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Collection Page"
    }
  ]
}
{% endschema %}
