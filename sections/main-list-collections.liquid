{% comment %}
  Sprout — sections/main-list-collections.liquid
  "Browse Collections" — full dynamic collection grid.
  Hero header · 3-column card grid · product count badges · empty-state handling.
  Configurable via theme Customizer: heading, subheading, show_empty toggle, padding.
{% endcomment %}

{{ 'sd-collection.css' | asset_url | stylesheet_tag }}

<section
  class="sdcl-gateway"
  aria-labelledby="sdcl-heading"
  style="padding-bottom: {{ section.settings.padding_bottom | default: 64 }}px;"
>

  {%- comment -%} ── Hero header ── {%- endcomment -%}
  <div class="sdcl-gateway__hero">
    <div class="sdcl-gateway__hero-inner">
      <h1 class="sdcl-gateway__hero-heading" id="sdcl-heading">
        {{ section.settings.heading | default: 'Browse Collections' | escape }}
      </h1>
      {%- if section.settings.subheading != blank -%}
        <p class="sdcl-gateway__hero-sub">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} ── Collection grid ── {%- endcomment -%}
  <div class="sdcl-gateway__inner" style="padding-top: {{ section.settings.padding_top | default: 48 }}px;">
    <div class="sdcl-gateway__grid sdcl-gateway__grid--3col">

      {%- for col in collections -%}

        {%- comment -%} Skip empty collections unless show_empty is enabled {%- endcomment -%}
        {%- if col.products_count == 0 and section.settings.show_empty == false -%}
          {%- continue -%}
        {%- endif -%}

        {%- comment -%} Auto-detect eyebrow label from collection title {%- endcomment -%}
        {%- liquid
          assign eyebrow = 'Trading Card Game'
          if col.title contains 'Pokemon' or col.title contains 'Pokémon'
            assign eyebrow = 'Pokémon TCG'
          elsif col.title contains 'One Piece'
            assign eyebrow = 'One Piece TCG'
          elsif col.title contains 'On Sale' or col.title contains 'Sale'
            assign eyebrow = 'Special Offer'
          elsif col.title contains 'Promo'
            assign eyebrow = 'Limited Edition'
          endif
        -%}

        <a
          href="{{ col.url }}"
          class="sdcl-card{% if col.products_count == 0 %} sdcl-card--empty{% endif %}"
          aria-label="{{ col.title | escape }} — {% if col.products_count == 0 %}Coming Soon{% else %}Shop Now{% endif %}"
        >
          <div class="sdcl-card__img-wrap">

            {%- if col.featured_image != blank -%}
              <img
                src="{{ col.featured_image | image_url: width: 900 }}"
                srcset="
                  {{ col.featured_image | image_url: width: 480 }} 480w,
                  {{ col.featured_image | image_url: width: 720 }} 720w,
                  {{ col.featured_image | image_url: width: 960 }} 960w"
                sizes="(max-width: 639px) 100vw, (max-width: 1023px) 50vw, 33vw"
                alt="{{ col.title | escape }}"
                class="sdcl-card__img"
                loading="lazy"
                width="900"
                height="675"
              >
            {%- else -%}
              <div class="sdcl-card__img sdcl-card__img--placeholder" aria-hidden="true"></div>
            {%- endif -%}

            {%- comment -%} Product count / Coming Soon badge {%- endcomment -%}
            {%- if col.products_count == 0 -%}
              <span class="sdcl-card__badge sdcl-card__badge--soon" aria-label="Coming soon">Coming Soon</span>
            {%- else -%}
              <span class="sdcl-card__badge" aria-label="{{ col.products_count }} products">
                {{- col.products_count -}}
                {%- if col.products_count == 1 %} product{%- else %} products{%- endif -%}
              </span>
            {%- endif -%}

            <div class="sdcl-card__overlay" aria-hidden="true">
              <div class="sdcl-card__content">
                <span class="sdcl-card__eyebrow">{{ eyebrow }}</span>
                <h2 class="sdcl-card__title">{{ col.title | escape }}</h2>
                <span class="sdcl-card__cta">
                  {%- if col.products_count == 0 -%}Explore{%- else -%}Shop Now{%- endif -%}
                  <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                    aria-hidden="true">
                    <path d="m9 18 6-6-6-6"/>
                  </svg>
                </span>
              </div>
            </div>

          </div>
        </a>

      {%- endfor -%}

    </div>
  </div>

</section>

{% schema %}
{
  "name": "Collection List",
  "tag": "section",
  "class": "sd-collection-gateway",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Page heading",
      "default": "Browse Collections"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Everything we carry — from sealed booster boxes to promos and specials."
    },
    {
      "type": "checkbox",
      "id": "show_empty",
      "label": "Show empty collections",
      "info": "When enabled, collections with no products appear with a 'Coming Soon' badge.",
      "default": false
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Grid top padding (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Collection List"
    }
  ]
}
{% endschema %}
